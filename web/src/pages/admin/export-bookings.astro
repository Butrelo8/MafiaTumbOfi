---
/**
 * Admin-only: fetches GET /api/admin/export/bookings and returns JSON download.
 * Use for debugging (e.g. verify production DB has expected submissions).
 */
import { isAuthenticated, redirectToSignIn, getToken } = Astro.locals.auth()

if (!isAuthenticated) {
  return redirectToSignIn({ returnBackUrl: '/admin/export-bookings' })
}

const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001'
const token = await getToken()

const response = await fetch(`${apiUrl}/api/admin/export/bookings`, {
  headers: token ? { Authorization: `Bearer ${token}` } : {},
})

if (!response.ok) {
  return new Response(
    JSON.stringify({ error: 'Export failed', status: response.status }),
    { status: response.status, headers: { 'Content-Type': 'application/json' } }
  )
}

const data = await response.json()
const filename = `bookings-export-${new Date().toISOString().slice(0, 10)}.json`

return new Response(JSON.stringify(data, null, 2), {
  status: 200,
  headers: {
    'Content-Type': 'application/json',
    'Content-Disposition': `attachment; filename="${filename}"`,
  },
})
---
