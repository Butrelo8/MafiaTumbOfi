---
import MarketingLayout from '../layouts/MarketingLayout.astro'
import { Show } from '@clerk/astro/components'
import { homeCanonical } from '../lib/publicSiteUrl'

import MemberCard from '../components/MemberCard.astro'
import { members } from '../data/members'
import 'aos/dist/aos.css'

const title = 'Mafia Tumbada — Oficial'
const description =
  'Sitio oficial de Mafia Tumbada. Bio, discografía, material de prensa y contacto para contrataciones. Corridos tumbados y regional mexicano desde Xalapa, Veracruz.'
const canonicalUrl = homeCanonical(import.meta.env.PUBLIC_SITE_URL, Astro.url.origin)

const photosUrl  = import.meta.env.PUBLIC_PRESS_PHOTOS_URL
const logoUrl    = import.meta.env.PUBLIC_PRESS_LOGO_URL
const bioUrl     = import.meta.env.PUBLIC_PRESS_BIO_URL
const whatsappUrl = import.meta.env.PUBLIC_WHATSAPP_URL

const spotifyUrl   = 'https://open.spotify.com/intl-es/artist/3pc90hxACiSUahZmmfYjcI'
const tiktokUrl    = 'https://www.tiktok.com/@mafia_tumbada_oficial'
const youtubeUrl   = 'https://www.youtube.com/@mafiatumbada'
const instagramUrl = 'https://www.instagram.com/mafia_tumbada_oficial/'
const applemusicUrl = 'https://music.apple.com/us/artist/mafia-tumbada/1777597386'
---

<MarketingLayout title={title} description={description} canonicalUrl={canonicalUrl}>

  <!-- Admin notice (solo visible si hay sesión) -->
  <Show when="signed-in">
    <div class="admin-notice">
      <span>Panel de admin:</span>
      <a href="/admin">Ver solicitudes</a>
    </div>
  </Show>

  <!-- ─── HERO ─────────────────────────────────────────────── -->
  <section class="hero">
    <video
      class="hero-video"
      autoplay
      muted
      playsinline
      loop
      aria-hidden="true"
    >
      <source src="/video/hero.mp4" type="video/mp4" />
    </video>
    <div class="hero-deco-line" aria-hidden="true"></div>
    <div class="container hero-content">
      <p class="hero-eyebrow">Sitio Oficial</p>
      <h1 class="hero-title">
        Mafia<br />
        <em>Tumbada</em>
      </h1>
      <div class="hero-meta">
        <span>Xalapa, Veracruz</span>
        <span>Corridos Tumbados</span>
        <span>Regional Mexicano</span>
        <span>Desde 2021</span>
      </div>
      <div class="hero-actions">
        <a href="#booking" class="btn-primary">Solicitar contratación</a>
        <a href="#press" class="btn-secondary">Material de prensa</a>
      </div>
    </div>
  </section>

  <!-- ─── STATS ─────────────────────────────────────────────── -->
  <div class="stats-bar">
    <div class="container">
      <div class="stat-item">
        <span class="stat-number">4</span>
        <span class="stat-label">Años activos</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">8</span>
        <span class="stat-label">Singles</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">+</span>
        <span class="stat-label">Presentaciones locales &amp; foráneas</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">Xalapa.</span>
        <span class="stat-label">Base: Veracruz, Méx.</span>
      </div>
    </div>
  </div>

  <!-- ─── BIO ───────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="bio-grid">
        <div class="bio-sidebar">
          <span class="section-label">Quiénes somos</span>
          <h2>El sonido de<br /> <em>Xalapa</em></h2>
          <div class="bio-tags">
            <span class="tag">Corridos Tumbados</span>
            <span class="tag">Norteño</span>
            <span class="tag">Regional Mx</span>
            <span class="tag">Covers</span>
            <span class="tag">Canciones propias</span>
          </div>
        </div>

        <div class="bio-body">
          <p>
            La Mafia Tumbada es un grupo de Xalapa, Veracruz que lleva cuatro años construyendo su propio espacio
            dentro del regional mexicano contemporáneo. Con raíces en el corrido tumbado y el norteño, y sin perder el
            pulso del regional clásico, el grupo mezcla canciones propias con covers ejecutados con honestidad y actitud.
          </p>
          <p>
            Tres singles originales acumulados en su catálogo son la muestra de un proyecto que toma en serio la
            composición propia. Al mismo tiempo, su versatilidad en tarima los ha llevado a barras y escenarios tanto en
            Veracruz como fuera del estado, consolidando un nombre que los promotores ya reconocen.
          </p>
          <p>
            El grupo está disponible para presentaciones, festivales, eventos privados y giras regionales. Cuentan con
            equipo propio y experiencia para adaptarse a diferentes formatos de producción.
          </p>
        </div>
      </div>
    </div>
  </section>
  <hr class="divider" />

  <!-- ─── REDES SOCIALES ────────────────────────────────────── -->
  <section class="section" id="redes">
    <div class="container">
      <span class="section-label">Síguenos</span>
      <h2 class="section-heading">Redes sociales</h2>

      <div class="socials-grid">
        <a
          href={spotifyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="social-card"
          aria-label="Spotify"
        >
          <span class="social-icon" aria-hidden="true">
            <!-- Spotify -->
            <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
              <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.516 17.318a.75.75 0 01-1.032.244c-2.827-1.727-6.387-2.117-10.578-1.16a.75.75 0 01-.336-1.462c4.587-1.05 8.52-.598 11.702 1.346a.75.75 0 01.244 1.032zm1.472-3.272a.938.938 0 01-1.29.308c-3.234-1.988-8.163-2.563-11.986-1.403a.937.937 0 11-.546-1.793c4.37-1.328 9.8-.685 13.514 1.598a.938.938 0 01.308 1.29zm.127-3.41C15.365 8.39 9.2 8.185 5.8 9.215a1.125 1.125 0 11-.653-2.153c3.96-1.2 10.545-.968 14.7 1.57a1.125 1.125 0 01-1.132 1.004z"/>
            </svg>
          </span>
          <span class="social-name">Spotify</span>
          <span class="social-handle">Escuchar música</span>
        </a>

        <a
          href={applemusicUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="social-card"
          aria-label="Apple Music"
        >
          <span class="social-icon" aria-hidden="true">
            <!-- Apple Music -->
            <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
              <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><title>Apple Music</title><path d="M23.994 6.124a9.23 9.23 0 00-.24-2.19c-.317-1.31-1.062-2.31-2.18-3.043a5.022 5.022 0 00-1.877-.726 10.496 10.496 0 00-1.564-.15c-.04-.003-.083-.01-.124-.013H5.986c-.152.01-.303.017-.455.026-.747.043-1.49.123-2.193.4-1.336.53-2.3 1.452-2.865 2.78-.192.448-.292.925-.363 1.408-.056.392-.088.785-.1 1.18 0 .032-.007.062-.01.093v12.223c.01.14.017.283.027.424.05.815.154 1.624.497 2.373.65 1.42 1.738 2.353 3.234 2.801.42.127.856.187 1.293.228.555.053 1.11.06 1.667.06h11.03a12.5 12.5 0 001.57-.1c.822-.106 1.596-.35 2.295-.81a5.046 5.046 0 001.88-2.207c.186-.42.293-.87.37-1.324.113-.675.138-1.358.137-2.04-.002-3.8 0-7.595-.003-11.393zm-6.423 3.99v5.712c0 .417-.058.827-.244 1.206-.29.59-.76.962-1.388 1.14-.35.1-.706.157-1.07.173-.95.045-1.773-.6-1.943-1.536a1.88 1.88 0 011.038-2.022c.323-.16.67-.25 1.018-.324.378-.082.758-.153 1.134-.24.274-.063.457-.23.51-.516a.904.904 0 00.02-.193c0-1.815 0-3.63-.002-5.443a.725.725 0 00-.026-.185c-.04-.15-.15-.243-.304-.234-.16.01-.318.035-.475.066-.76.15-1.52.303-2.28.456l-2.325.47-1.374.278c-.016.003-.032.01-.048.013-.277.077-.377.203-.39.49-.002.042 0 .086 0 .13-.002 2.602 0 5.204-.003 7.805 0 .42-.047.836-.215 1.227-.278.64-.77 1.04-1.434 1.233-.35.1-.71.16-1.075.172-.96.036-1.755-.6-1.92-1.544-.14-.812.23-1.685 1.154-2.075.357-.15.73-.232 1.108-.31.287-.06.575-.116.86-.177.383-.083.583-.323.6-.714v-.15c0-2.96 0-5.922.002-8.882 0-.123.013-.25.042-.37.07-.285.273-.448.546-.518.255-.066.515-.112.774-.165.733-.15 1.466-.296 2.2-.444l2.27-.46c.67-.134 1.34-.27 2.01-.403.22-.043.442-.088.663-.106.31-.025.523.17.554.482.008.073.012.148.012.223.002 1.91.002 3.822 0 5.732z"/></svg>
            </svg>
          </span>
          <span class="social-name">Apple Music</span>
          <span class="social-handle">Escuchar música</span>
        </a>

        <a
          href={instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="social-card"
          aria-label="Instagram"
        >
          <span class="social-icon" aria-hidden="true">
            <!-- Instagram -->
            <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </span>
          <span class="social-name">Instagram</span>
          <span class="social-handle">@mafia_tumbada_oficial</span>
        </a>

        <a
          href={tiktokUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="social-card"
          aria-label="TikTok"
        >
          <span class="social-icon" aria-hidden="true">
            <!-- TikTok -->
            <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.17 8.17 0 004.77 1.52V6.74a4.85 4.85 0 01-1-.05z"/>
            </svg>
          </span>
          <span class="social-name">TikTok</span>
          <span class="social-handle">@mafia_tumbada_oficial</span>
        </a>

        <a
          href={youtubeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="social-card"
          aria-label="YouTube"
        >
          <span class="social-icon" aria-hidden="true">
            <!-- YouTube -->
            <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
              <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </span>
          <span class="social-name">YouTube</span>
          <span class="social-handle">@mafiatumbada</span>
        </a>
      </div>
    </div>
  </section>
  <hr class="divider" />

  <!-- ─── DISCOGRAFÍA ───────────────────────────────────────── -->
  <section class="section" id="musica">
    <div class="container">
      <span class="section-label">Discografía</span>
      <h2 class="section-heading">Material original</h2>

      <div class="singles-grid">
        <div class="single-card">
          <span class="single-number">01</span>
          <div>
            <p class="single-title">L.V.</p>
            <p class="single-meta">Single · Corrido Tumbado</p>
          </div>
        </div>
        <div class="single-card">
          <span class="single-number">02</span>
          <div>
            <p class="single-title">L.A. BUBU</p>
            <p class="single-meta">Single · Corrido Tumbado</p>
          </div>
        </div>
        <div class="single-card">
          <span class="single-number">03</span>
          <div>
            <p class="single-title">No Te He Olvidado</p>
            <p class="single-meta">Single · Regional Mexicano</p>
          </div>
        </div>
        <div class="single-card">
          <span class="single-number">04</span>
          <div>
            <p class="single-title">Tal Vez</p>
            <p class="single-meta">Single · Corrido Tumbado</p>
          </div>
        </div>
        <div class="single-card">
          <span class="single-number">05</span>
          <div>
            <p class="single-title">Corazón</p>
            <p class="single-meta">Single · Regional Mexicano</p>
          </div>
        </div>
        <div class="single-card">
          <span class="single-number">06</span>
          <div>
            <p class="single-title">Besos</p>
            <p class="single-meta">Single · Corrido Tumbado</p>
          </div>
        </div>
        <div class="single-card">
          <span class="single-number">07</span>
          <div>
            <p class="single-title">Mírame</p>
            <p class="single-meta">Single · Regional Mexicano</p>
          </div>
        </div>
        <div class="single-card">
          <span class="single-number">08</span>
          <div>
            <p class="single-title">Sd</p>
            <p class="single-meta">Single · Corrido Tumbado</p>
          </div>
        </div>
      </div>

      <div class="streaming-ctas">
        <a
          href={spotifyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          Escuchar discografía completa en Spotify
        </a>
        <a
          href={applemusicUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          Escuchar discografía completa en Apple Music
        </a>
      </div>
    </div>
  </section>
  <hr class="divider" />

  <!-- ─── INTEGRANTES ───────────────────────────────────────── -->
  <section class="section" id="grupo">
    <div class="container">
      <span class="section-label">El grupo</span>
      <h2 class="section-heading">Integrantes</h2>

      <div class="members-grid">
        {members.map(member => (
          <MemberCard {...member} />
        ))}
      </div>
    </div>
  </section>
  <hr class="divider" />

  <!-- ─── PRESENTACIONES ────────────────────────────────────── -->
  <section class="section" id="shows">
    <div class="container">
      <span class="section-label">En tarima</span>
      <h2 class="section-heading">Presentaciones</h2>
      <p class="shows-intro">
        Desde los bares de Xalapa hasta plazas fuera del estado, la Mafia Tumbada ha construido su reputación tocando
        en vivo. Cada fecha suma al historial de un grupo que trabaja en serio.
      </p>

      <div class="shows-list">
        <div class="show-item">
          <span class="show-dot"></span>
          <div>
            <p class="show-name">La Bohemia</p>
            <p class="show-loc">Misantla, Veracruz</p>
          </div>
        </div>
        <div class="show-item">
          <span class="show-dot"></span>
          <div>
            <p class="show-name">San Benito</p>
            <p class="show-loc">Xalapa, Veracruz</p>
          </div>
        </div>
        <div class="show-item">
          <span class="show-dot"></span>
          <div>
            <p class="show-name">Jala la Jarra</p>
            <p class="show-loc">Xalapa, Veracruz</p>
          </div>
        </div>
        <div class="show-item show-item--placeholder">
          <span class="show-dot show-dot--muted"></span>
          <div>
            <p class="show-name show-name--muted">+ más fechas</p>
            <p class="show-loc">Historial completo bajo solicitud</p>
          </div>
        </div>
      </div>

      <p class="shows-note">
        * El historial completo de presentaciones se comparte bajo solicitud de booking.
      </p>
    </div>
  </section>
  <hr class="divider" />

  <!-- ─── ASSETS DE PRENSA ──────────────────────────────────── -->
  <section class="section" id="press">
    <div class="container">
      <span class="section-label">Material de prensa</span>
      <h2 class="section-heading">Descarga assets</h2>

      <div class="assets-grid">
        <div class="asset-card">
          <span class="asset-icon" aria-hidden="true">🖼</span>
          <p class="asset-name">Fotografías oficiales</p>
          <p class="asset-desc">
            Fotos de alta resolución para imprenta y medios digitales. Uso libre con crédito al grupo.
          </p>
          {
            photosUrl ? (
              <a href={photosUrl} class="asset-btn" target="_blank" rel="noopener noreferrer">
                ↓ Descargar
              </a>
            ) : (
              <span class="asset-btn--pending" aria-disabled="true">Próximamente</span>
            )
          }
        </div>
        <div class="asset-card">
          <span class="asset-icon" aria-hidden="true">◈</span>
          <p class="asset-name">Logotipo</p>
          <p class="asset-desc">PNG y SVG en versión oscura, clara y monocromática. Fondo transparente incluido.</p>
          {
            logoUrl ? (
              <a href={logoUrl} class="asset-btn" target="_blank" rel="noopener noreferrer">
                ↓ Descargar
              </a>
            ) : (
              <span class="asset-btn--pending" aria-disabled="true">Próximamente</span>
            )
          }
        </div>
        <div class="asset-card">
          <span class="asset-icon" aria-hidden="true">📄</span>
          <p class="asset-name">Bio corta (texto)</p>
          <p class="asset-desc">
            Versión de 80 palabras lista para programas, redes y comunicados de prensa.
          </p>
          {
            bioUrl ? (
              <a href={bioUrl} class="asset-btn" target="_blank" rel="noopener noreferrer">
                ↓ Descargar
              </a>
            ) : (
              <span class="asset-btn--pending" aria-disabled="true">Próximamente</span>
            )
          }
        </div>
        <div class="asset-card">
          <span class="asset-icon" aria-hidden="true">🎵</span>
          <p class="asset-name">Singles en streaming</p>
          <p class="asset-desc">
            Spotify, Apple Music y YouTube. También disponibles stems para radio bajo solicitud.
          </p>
          <a href={spotifyUrl} target="_blank" rel="noopener noreferrer" class="asset-btn">→ Escuchar</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── BOOKING CTA ───────────────────────────────────────── -->
  <section class="booking section" id="booking">
    <div class="container">
      <div>
        <p class="section-label">Contratar al grupo</p>
        <h2 class="booking-headline">
          ¿Tienes una<br /> <em>fecha disponible?</em>
        </h2>
        <p class="booking-sub">
          Respondemos cotizaciones en menos de 24 horas. Incluye fecha, ciudad y tipo de evento para agilizar la
          respuesta.
        </p>
      </div>
      <div class="booking-actions">
        <a href="/booking" class="btn-primary">Solicitar cotización</a>
        {
          whatsappUrl ? (
            <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary">
              WhatsApp directo
            </a>
          ) : null
        }
      </div>
    </div>
  </section>

  <!-- ─── FOOTER ────────────────────────────────────────────── -->
  <footer class="footer-bar">
    <div class="container">
      <span class="footer-brand">Mafia Tumbada</span>
      <div class="footer-socials">
        <a href={spotifyUrl}   target="_blank" rel="noopener noreferrer" aria-label="Spotify">Spotify</a>
        <a href={applemusicUrl}   target="_blank" rel="noopener noreferrer" aria-label="Apple Music">Apple Music</a>
        <a href={instagramUrl} target="_blank" rel="noopener noreferrer" aria-label="Instagram">Instagram</a>
        <a href={tiktokUrl}    target="_blank" rel="noopener noreferrer" aria-label="TikTok">TikTok</a>
        <a href={youtubeUrl}   target="_blank" rel="noopener noreferrer" aria-label="YouTube">YouTube</a>
      </div>
      <p class="footer-copy">
        © {new Date().getFullYear()} · Xalapa, Veracruz · Todos los derechos reservados
      </p>
    </div>
  </footer>

</MarketingLayout>

<script>
  import AOS from 'aos';
  AOS.init({
    duration: 800,
    once: true,
  });
</script>

<style>
  .members-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    margin-top: 2rem;
    border: none;
    background: transparent;
  }

  /* Admin notice */
  .admin-notice {
    background: var(--color-brand, #c8a96e);
    color: #000;
    text-align: center;
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
  }
  .admin-notice a {
    margin-left: 0.5rem;
    text-decoration: underline;
  }

