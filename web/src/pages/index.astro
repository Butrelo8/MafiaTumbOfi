            <path d="M23.272,53.04 C14.0460542,50.3561172 7.31516808,42.4211504 6.172,32.881 C6.12948539,32.5262353 5.90093555,32.2211004 5.57244298,32.0805368 C5.24395041,31.9399731 4.86542094,31.9853357 4.57944298,32.1995368 C4.29346501,32.4137379 4.14348539,32.7642353 4.186,33.119 C5.42507198,43.454666 12.7169523,52.0513386 22.712,54.96 C23.054975,55.0600344 23.4252646,54.969495 23.6833844,54.7224871 C23.9415042,54.4754793 24.0482396,54.1095293 23.9633844,53.7624871 C23.8785292,53.4154449 23.614975,53.1400344 23.272,53.04 Z"/>
            <path d="M32.881,53.828 C30.9671594,54.0570035 29.0328406,54.0570035 27.119,53.828 C26.5705813,53.7622781 26.0727219,54.1535813 26.007,54.702 C25.9412781,55.2504187 26.3325813,55.7482781 26.881,55.814 C28.9529387,56.0619997 31.0470613,56.0619997 33.119,55.814 C33.6674187,55.7482781 34.0587219,55.2504188 33.993,54.702 C33.9272781,54.1535813 33.4294188,53.7622781 32.881,53.828 Z"/>
            <path d="M41.441,6.655 C40.945708,6.41382261 40.3486434,6.61864423 40.105699,7.11307188 C39.8627546,7.60749954 40.065443,8.20529169 40.559,8.45 C48.8050842,12.4571052 54.0285493,20.8319042 54,30 C54,30.5522847 54.4477153,31 55,31 C55.5522847,31 56,30.5522847 56,30 C56.031417,20.0685475 50.3734692,10.9961668 41.441,6.655 Z"/>
            <path d="M30,6 C31.2864451,6.00040386 32.5708229,6.10306046 33.841,6.307 C33.8939649,6.31493611 33.9474439,6.31894704 34.001,6.319 C34.5215067,6.31759572 34.9538966,5.9171411 34.9951555,5.3982703 C35.0364145,4.87939949 34.6727439,4.41564464 34.159,4.332 C32.783729,4.11067943 31.3929655,3.99965912 30,4 C29.4477153,4 29,4.44771525 29,5 C29,5.55228475 29.4477153,6 30,6 Z"/>
            <path fill-rule="nonzero" d="M30,0 C13.4314575,0 0,13.4314575 0,30 C0,46.5685425 13.4314575,60 30,60 C46.5685425,60 60,46.5685425 60,30 C59.981263,13.4392249 46.5607751,0.0187370435 30,0 Z M30,58 C14.536027,58 2,45.463973 2,30 C2,14.536027 14.536027,2 30,2 C45.463973,2 58,14.536027 58,30 C57.9823655,45.4566626 45.4566626,57.9823655 30,58 Z"/>
            <path fill-rule="nonzero" d="M30,19 C23.9248678,19 19,23.9248678 19,30 C19,36.0751322 23.9248678,41 30,41 C36.0751322,41 41,36.0751322 41,30 C40.9928365,23.9278374 36.0721626,19.0071635 30,19 Z M30,39 C25.0294373,39 21,34.9705627 21,30 C21,25.0294373 25.0294373,21 30,21 C34.9705627,21 39,25.0294373 39,30 C38.9944889,34.9682782 34.9682782,38.9944889 30,39 Z"/>
            <path fill-rule="nonzero" d="M30,26 C27.790861,26 26,27.790861 26,30 C26,32.209139 27.790861,34 30,34 C32.209139,34 34,32.209139 34,30 C34,27.790861 32.209139,26 30,26 Z M30,32 C28.8954305,32 28,31.1045695 28,30 C28,28.8954305 28.8954305,28 30,28 C31.1045695,28 32,28.8954305 32,30 C32,31.1045695 31.1045695,32 30,32 Z"/>
          </svg>
        </span>
        <span>Repertorio propio + covers</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18">
            <path d="M21.0039 12C21.0039 16.9706 16.9745 21 12.0039 21H3.00463C3.00463 21 4.56382 17.2561 3.93982 16.0008C3.34076 14.7956 3.00391 13.4372 3.00391 12C3.00391 7.02944 7.03334 3 12.0039 3M20.1213 3.87868C21.2929 5.05025 21.2929 6.94975 20.1213 8.12132C18.9497 9.29289 17.0503 9.29289 15.8787 8.12132C14.7071 6.94975 14.7071 5.05025 15.8787 3.87868C17.0503 2.70711 18.9497 2.70711 20.1213 3.87868Z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span>Respuesta por Whatsapp o formulario</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" stroke="none" width="18" height="18">
          <path d="M13.29 14.667L11 16.097V3.81l3-1.5v5.968a6.182 6.182 0 0 1 1-1.104V2.307l3.024 1.503-.003 1.974A6.275 6.275 0 0 1 19 5.7l.02.001.005-2.51L14.5.94l-4 2-4-2L2 3.191V17.9l4.5-2.811 4 2.5 3.15-1.968q-.202-.485-.36-.955zM6 14.223l-3.001 1.876-.023-12.29L6 2.308zm4 1.875l-3-1.875V2.309l3 1.5zM19 7a4.96 4.96 0 0 0-4.9 5.086c0 2.807 2.678 6.606 4.9 10.914 2.222-4.308 4.9-8.107 4.9-10.914A4.96 4.96 0 0 0 19 7zm0 13.877c-.298-.543-.598-1.077-.89-1.6-1.548-2.762-3.01-5.37-3.01-7.191a3.905 3.905 0 1 1 7.8 0c0 1.82-1.462 4.429-3.01 7.19-.292.524-.592 1.058-.89 1.601zm0-11.043A2.166 2.166 0 1 0 21.13 12 2.147 2.147 0 0 0 19 9.834zm0 3.332A1.167 1.167 0 1 1 20.13 12 1.15 1.15 0 0 1 19 13.166z"/><path fill="none" d="M0 0h24v24H0z"/></svg>
          </svg>
        </span>
        <span>Disponibles para eventos foraneos</span>
      </div>
    </div>
  </section>

  <!-- ─── BIO ───────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="bio-grid">
        <div class="bio-sidebar" data-aos="fade-up">
          <span class="section-label">Quiénes somos</span>
          <h2>El sonido de<br /> <em>Xalapa</em></h2>
          <div class="bio-tags">
            <span class="tag">Corridos Tumbados</span>
            <span class="tag">Norteño</span>
            <span class="tag">Regional Mx</span>
            <span class="tag">Covers</span>
            <span class="tag">Canciones propias</span>
          </div>
        </div>

        <div class="bio-body" data-aos="fade-up">
          <p>
            La Mafia Tumbada es un grupo de Xalapa, Veracruz que lleva cuatro años construyendo su propio espacio
            dentro del regional mexicano contemporáneo. Con raíces en el corrido tumbado y el norteño, y sin perder el
            pulso del regional clásico, el grupo mezcla canciones propias con covers ejecutados con honestidad y actitud.
          </p>
          <p>
            Ocho singles originales acumulados en su catálogo son la muestra de un proyecto que toma en serio la
            composición propia. Al mismo tiempo, su versatilidad en tarima los ha llevado a barras y escenarios tanto en
            Veracruz como fuera del estado, consolidando un nombre que los promotores ya reconocen.
          </p>
          <p>
            El grupo está disponible para presentaciones, festivales, eventos privados y giras regionales. Cuentan con
            equipo propio y experiencia para adaptarse a diferentes formatos de producción.
          </p>
        </div>
      </div>
    </div>
  </section>
  <hr class="divider" />

  <!-- ─── REPERTORIO ─────────────────────────────────────────── -->
  <section class="section" id="repertorio" aria-labelledby="repertorio-heading">
    <div class="container">
      <span class="section-label">En vivo</span>
      <h2 id="repertorio-heading" class="section-heading">Repertorio</h2>
      <p class="repertoire-intro">
        Del corrido tumbado al regional clásico: sets armados según el tipo de evento y el público.
      </p>

      <div class="repertoire-grid">
        {repertoireItems.map((item) => (
          <article class="repertoire-card" data-aos="fade-up">
            <h3 class="repertoire-name">{item.name}</h3>
            <p class="repertoire-desc">{item.description}</p>
          </article>
        ))}
      </div>

      <div
        class="repertoire-cta"
        role="group"
        aria-label="Escuchar en streaming y solicitar contratación"
      >
        <div class="repertoire-stream">
          <a
            href={bandSocialUrls.appleMusic}
            target="_blank"
            rel="noopener noreferrer"
            class="repertoire-stream-link"
          >
            <span class="repertoire-stream-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                <path d="M23.994 6.124a9.23 9.23 0 00-.24-2.19c-.317-1.31-1.062-2.31-2.18-3.043a5.022 5.022 0 00-1.877-.726 10.496 10.496 0 00-1.564-.15c-.04-.003-.083-.01-.124-.013H5.986c-.152.01-.303.017-.455.026-.747.043-1.49.123-2.193.4-1.336.53-2.3 1.452-2.865 2.78-.192.448-.292.925-.363 1.408-.056.392-.088.785-.1 1.18 0 .032-.007.062-.01.093v12.223c.01.14.017.283.027.424.05.815.154 1.624.497 2.373.65 1.42 1.738 2.353 3.234 2.801.42.127.856.187 1.293.228.555.053 1.11.06 1.667.06h11.03a12.5 12.5 0 001.57-.1c.822-.106 1.596-.35 2.295-.81a5.046 5.046 0 001.88-2.207c.186-.42.293-.87.37-1.324.113-.675.138-1.358.137-2.04-.002-3.8 0-7.595-.003-11.393zm-6.423 3.99v5.712c0 .417-.058.827-.244 1.206-.29.59-.76.962-1.388 1.14-.35.1-.706.157-1.07.173-.95.045-1.773-.6-1.943-1.536a1.88 1.88 0 011.038-2.022c.323-.16.67-.25 1.018-.324.378-.082.758-.153 1.134-.24.274-.063.457-.23.51-.516a.904.904 0 00.02-.193c0-1.815 0-3.63-.002-5.443a.725.725 0 00-.026-.185c-.04-.15-.15-.243-.304-.234-.16.01-.318.035-.475.066-.76.15-1.52.303-2.28.456l-2.325.47-1.374.278c-.016.003-.032.01-.048.013-.277.077-.377.203-.39.49-.002.042 0 .086 0 .13-.002 2.602 0 5.204-.003 7.805 0 .42-.047.836-.215 1.227-.278.64-.77 1.04-1.434 1.233-.35.1-.71.16-1.075.172-.96.036-1.755-.6-1.92-1.544-.14-.812.23-1.685 1.154-2.075.357-.15.73-.232 1.108-.31.287-.06.575-.116.86-.177.383-.083.583-.323.6-.714v-.15c0-2.96 0-5.922.002-8.882 0-.123.013-.25.042-.37.07-.285.273-.448.546-.518.255-.066.515-.112.774-.165.733-.15 1.466-.296 2.2-.444l2.27-.46c.67-.134 1.34-.27 2.01-.403.22-.043.442-.088.663-.106.31-.025.523.17.554.482.008.073.012.148.012.223.002 1.91.002 3.822 0 5.732z"/>
              </svg>
            </span>
            <span>Apple Music</span>
          </a>
          <a
            href={bandSocialUrls.spotify}
            target="_blank"
            rel="noopener noreferrer"
            class="repertoire-stream-link"
          >
            <span class="repertoire-stream-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.516 17.318a.75.75 0 01-1.032.244c-2.827-1.727-6.387-2.117-10.578-1.16a.75.75 0 01-.336-1.462c4.587-1.05 8.52-.598 11.702 1.346a.75.75 0 01.244 1.032zm1.472-3.272a.938.938 0 01-1.29.308c-3.234-1.988-8.163-2.563-11.986-1.403a.937.937 0 11-.546-1.793c4.37-1.328 9.8-.685 13.514 1.598a.938.938 0 01.308 1.29zm.127-3.41C15.365 8.39 9.2 8.185 5.8 9.215a1.125 1.125 0 11-.653-2.153c3.96-1.2 10.545-.968 14.7 1.57a1.125 1.125 0 01-1.132 1.004z"/>
              </svg>
            </span>
            <span>Spotify</span>
          </a>
          <a
            href={bandSocialUrls.youtube}
            target="_blank"
            rel="noopener noreferrer"
            class="repertoire-stream-link"
          >
            <span class="repertoire-stream-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </span>
            <span>YouTube</span>
          </a>
        </div>
        <a href="/booking" class="btn-primary repertoire-cta-booking">Solicitar contratación</a>
      </div>
    </div>
  </section>
  <hr class="divider" />

  <!-- ─── REDES SOCIALES ────────────────────────────────────── -->
  <section class="section" id="redes">
    <div class="container">
      <span class="section-label">Síguenos</span>
      <h2 class="section-heading">Redes sociales</h2>

      <div class="socials-grid">
        <a
          href={bandSocialUrls.spotify}
          target="_blank"
          rel="noopener noreferrer"
          class="social-card"
          aria-label="Spotify"
        >
          <span class="social-icon" aria-hidden="true">
            <!-- Spotify -->
            <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
              <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.516 17.318a.75.75 0 01-1.032.244c-2.827-1.727-6.387-2.117-10.578-1.16a.75.75 0 01-.336-1.462c4.587-1.05 8.52-.598 11.702 1.346a.75.75 0 01.244 1.032zm1.472-3.272a.938.938 0 01-1.29.308c-3.234-1.988-8.163-2.563-11.986-1.403a.937.937 0 11-.546-1.793c4.37-1.328 9.8-.685 13.514 1.598a.938.938 0 01.308 1.29zm.127-3.41C15.365 8.39 9.2 8.185 5.8 9.215a1.125 1.125 0 11-.653-2.153c3.96-1.2 10.545-.968 14.7 1.57a1.125 1.125 0 01-1.132 1.004z"/>
            </svg>
          </span>
          <span class="social-name">Spotify</span>
          <span class="social-handle">Escuchar música</span>
        </a>

        <a
          href={bandSocialUrls.appleMusic}
          target="_blank"
          rel="noopener noreferrer"
          class="social-card"
          aria-label="Apple Music"
        >
          <span class="social-icon" aria-hidden="true">
            <!-- Apple Music -->
            <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
