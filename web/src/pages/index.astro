---
import MarketingLayout from '../layouts/MarketingLayout.astro'
import { Show } from '@clerk/astro/components'
import { homeCanonical } from '../lib/publicSiteUrl'

import MemberCard from '../components/MemberCard.astro'
import { members } from '../data/members'
import { packageTiers } from '../data/packages'
import { repertoireItems } from '../data/repertoire'
import { bandSocialUrls } from '../data/socials'
import { testimonials } from '../data/testimonials'
import 'aos/dist/aos.css'

const title = 'Mafia Tumbada — Oficial'
const description =
  'Sitio oficial de Mafia Tumbada. Bio, discografía, material de prensa y contacto para contrataciones. Corridos tumbados y regional mexicano desde Xalapa, Veracruz.'
const canonicalUrl = homeCanonical(import.meta.env.PUBLIC_SITE_URL, Astro.url.origin)

const photosUrl  = import.meta.env.PUBLIC_PRESS_PHOTOS_URL
const logoUrl    = import.meta.env.PUBLIC_PRESS_LOGO_URL
const bioUrl     = import.meta.env.PUBLIC_PRESS_BIO_URL
const whatsappUrl = import.meta.env.PUBLIC_WHATSAPP_URL
---

<MarketingLayout title={title} description={description} canonicalUrl={canonicalUrl} hasHero={true}>

  <!-- Admin notice (solo visible si hay sesión) -->
  <Show when="signed-in">
    <div class="admin-notice">
      <span>Panel de admin:</span>
      <a href="/admin">Ver solicitudes</a>
    </div>
  </Show>

  <!-- ─── HERO ─────────────────────────────────────────────── -->
  <section class="hero">
    <video
      class="hero-video"
      autoplay
      muted
      playsinline
      loop
      aria-hidden="true"
    >
      <source src="/video/hero.mp4" type="video/mp4" />
    </video>
    <div class="hero-deco-line" aria-hidden="true"></div>
    <div class="container hero-content">
      <p class="hero-eyebrow">Sitio Oficial</p>
      <h1 class="hero-title">
        <img src="/icon/mafiatumbada.png" alt="Mafia Tumbada" class="hero-logo-img" />
      </h1>
      <div class="hero-meta">
        <span>Xalapa, Veracruz</span>
        <span>Corridos Tumbados</span>
        <span>Regional Mexicano</span>
        <span>Desde 2021</span>
      </div>
      <p class="hero-blurb">
        La Mafia Tumbada es un grupo de corridos tumbados y regional mexicano con base en Xalapa, Veracruz. Las
        contrataciones cubren presentaciones en vivo, festivales, barras y eventos privados; aquí puedes conocer el
        proyecto y solicitar una cotización sin compromiso.
      </p>
      <div class="hero-actions">
        <a href="#booking" class="btn-primary">Solicitar contratación</a>
        <a href="#press" class="btn-secondary">Material de prensa</a>
      </div>
    </div>
  </section>

  <!-- ─── STATS ─────────────────────────────────────────────── -->
  <div class="stats-bar">
    <div class="container">
      <div class="stat-item">
        <span class="stat-number">4</span>
        <span class="stat-label">Años activos</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">8</span>
        <span class="stat-label">Singles</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">+</span>
        <span class="stat-label">Presentaciones locales &amp; foráneas</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">Xalapa.</span>
        <span class="stat-label">Base: Veracruz, Méx.</span>
      </div>
    </div>
  </div>

  <!-- ─── TRUST STRIP ─────────────────────────────────────────── -->
  <section class="trust-strip" aria-labelledby="trust-heading">
    <h2 id="trust-heading" class="sr-only">Por qué contratar a Mafia Tumbada</h2>
    <div class="trust-grid">
      <div class="trust-item">
        <span class="trust-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-miterlimit="10">
            <polyline points="6.5,14.5 10.5,18.5 17.5,10.5"/>
            <rect x="0.5" y="6.5" width="23" height="17"/>
            <polyline points="0.5,6.5 0.5,1.5 23.5,1.5 23.5,6.5"/>
            <line x1="11.5" y1="3.5" x2="11.5" y2="0.5"/>
            <line x1="17.5" y1="3.5" x2="17.5" y2="0.5"/>
            <line x1="5.5" y1="3.5" x2="5.5" y2="0.5"/>
          </svg>
        </span>
        <span>+20 eventos en estos 4 años</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
            <path d="M50.16,24.029 C49.6242283,24.1610201 49.2966484,24.702064 49.428,25.238 C49.8090627,26.7966296 50.001111,28.3954646 50,30 C50,30.5522847 50.4477153,31 51,31 C51.5522847,31 52,30.5522847 52,30 C52.0010376,28.2349801 51.7891741,26.4762783 51.369,24.762 C51.2374322,24.2258226 50.6962451,23.8977083 50.16,24.029 Z"/>
