---
import MarketingLayout from '../layouts/MarketingLayout.astro'
import { pressKitCanonical } from '../lib/publicSiteUrl'

const title = 'Press Kit — La Mafia Tumbada'
const description =
  'Información oficial, bio, material de prensa y contacto de booking para La Mafia Tumbada. Grupo de corridos tumbados y regional mexicano, Xalapa, Veracruz.'
const canonicalUrl = pressKitCanonical(import.meta.env.PUBLIC_SITE_URL, Astro.url.origin)
const photosUrl = import.meta.env.PUBLIC_PRESS_PHOTOS_URL
const logoUrl = import.meta.env.PUBLIC_PRESS_LOGO_URL
const bioUrl = import.meta.env.PUBLIC_PRESS_BIO_URL
const whatsappUrl = import.meta.env.PUBLIC_WHATSAPP_URL
const spotifyArtistUrl = 'https://open.spotify.com/intl-es/artist/3pc90hxACiSUahZmmfYjcI'
---

<MarketingLayout title={title} description={description} canonicalUrl={canonicalUrl}>
  <section class="hero">
    <div class="container hero-content">
      <p class="hero-eyebrow">Press Kit Oficial</p>
      <h1 class="hero-title">
        La Mafia<br />
        <em>Tumbada</em>
      </h1>
      <div class="hero-meta">
        <span>Xalapa, Veracruz</span>
        <span>Corridos Tumbados</span>
        <span>Regional Mexicano</span>
        <span>Desde 2021</span>
      </div>
    </div>
  </section>

  <div class="stats-bar">
    <div class="container">
      <div class="stat-item">
        <span class="stat-number">4</span>
        <span class="stat-label">Años activos</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">7</span>
        <span class="stat-label">Singles en Spotify</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">+</span>
        <span class="stat-label">Presentaciones locales & foráneas</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">Ver.</span>
        <span class="stat-label">Base: Veracruz, Méx.</span>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="bio-grid">
        <div class="bio-sidebar">
          <span class="section-label">Quiénes somos</span>
          <h2>El sonido de<br /> <em>Xalapa</em></h2>
          <div class="bio-tags">
            <span class="tag">Corridos Tumbados</span>
            <span class="tag">Norteño</span>
            <span class="tag">Regional Mx</span>
            <span class="tag">Covers</span>
            <span class="tag">Canciones propias</span>
          </div>
        </div>

        <div class="bio-body">
          <p>
            La Mafia Tumbada es un grupo de Xalapa, Veracruz que lleva cuatro años construyendo su propio espacio
            dentro del regional mexicano contemporáneo. Con raíces en el corrido tumbado y el norteño, y sin perder el
            pulso del regional clásico, el grupo mezcla canciones propias con covers ejecutados con honestidad y actitud.
          </p>
          <p>
            Tres singles originales acumulados en su catálogo son la muestra de un proyecto que toma en serio la
            composición propia. Al mismo tiempo, su versatilidad en tarima los ha llevado a barras y escenarios tanto en
            Veracruz como fuera del estado, consolidando un nombre que los promotores ya reconocen.
          </p>
          <p>
            El grupo está disponible para presentaciones, festivales, eventos privados y giras regionales. Cuentan con
            equipo propio y experiencia para adaptarse a diferentes formatos de producción.
          </p>
        </div>
      </div>
    </div>
  </section>
  <hr class="divider" />

  <section class="section">
    <div class="container">
      <span class="section-label">Discografía</span>
      <h2 class="section-heading">Material original</h2>

      <div class="singles-grid">
        <div class="single-card">
          <span class="single-number">01</span>
          <div>
            <p class="single-title">L.A. BUBU</p>
            <p class="single-meta">Single · Corrido Tumbado</p>
          </div>
        </div>
        <div class="single-card">
          <span class="single-number">02</span>
          <div>
            <p class="single-title">No Te He Olvidado</p>
            <p class="single-meta">Single · Regional Mexicano</p>
          </div>
        </div>
        <div class="single-card">
          <span class="single-number">03</span>
          <div>
            <p class="single-title">Tal Vez</p>
            <p class="single-meta">Single · Corrido Tumbado</p>
          </div>
        </div>
        <div class="single-card">
          <span class="single-number">04</span>
          <div>
            <p class="single-title">Corazón</p>
            <p class="single-meta">Single · Regional Mexicano</p>
          </div>
        </div>
        <div class="single-card">
          <span class="single-number">05</span>
          <div>
            <p class="single-title">Besos</p>
            <p class="single-meta">Single · Corrido Tumbado</p>
          </div>
        </div>
        <div class="single-card">
          <span class="single-number">06</span>
          <div>
            <p class="single-title">Mírame</p>
            <p class="single-meta">Single · Regional Mexicano</p>
          </div>
        </div>
        <div class="single-card">
          <span class="single-number">07</span>
          <div>
            <p class="single-title">Sd</p>
            <p class="single-meta">Single · Corrido Tumbado</p>
          </div>
        </div>
      </div>

      <div class="spotify-cta-wrap">
        <a
          href={spotifyArtistUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary spotify-cta"
        >
          Ver discografía completa en Spotify
        </a>
      </div>
    </div>
  </section>
  <hr class="divider" />

  <section class="section">
    <div class="container">
      <span class="section-label">El grupo</span>
      <h2 class="section-heading">Integrantes</h2>

      <div class="members-grid">
        <div class="member-card">
          <span class="member-role">Vocal Principal</span>
          <p class="member-name">Héctor Báez</p>
        </div>
        <div class="member-card">
          <span class="member-role">Requintista &amp; Vocal</span>
          <p class="member-name">Alexandro Montal</p>
        </div>
        <div class="member-card">
          <span class="member-role">Guitarra</span>
          <p class="member-name">Diego Cerecer</p>
        </div>
        <div class="member-card">
          <span class="member-role">Trombón</span>
          <p class="member-name">Dimora</p>
        </div>
      </div>
    </div>
  </section>
  <hr class="divider" />

  <section class="section">
    <div class="container">
      <span class="section-label">En tarima</span>
      <h2 class="section-heading">Presentaciones</h2>
      <p class="shows-intro">
        Desde los bares de Xalapa hasta plazas fuera del estado, La Mafia Tumbada ha construido su reputación tocando
        en vivo. Cada fecha suma al historial de un grupo que trabaja en serio.
      </p>

      <div class="shows-list">
        <div class="show-item">
          <span class="show-dot"></span>
          <div>
            <p class="show-name">La Bohemia</p>
            <p class="show-loc">Misantla, Veracruz</p>
          </div>
        </div>
        <div class="show-item">
          <span class="show-dot"></span>
          <div>
            <p class="show-name">San Benito</p>
            <p class="show-loc">Xalapa, Veracruz</p>
          </div>
        </div>
        <div class="show-item">
          <span class="show-dot"></span>
          <div>
            <p class="show-name">Jala la Jarra</p>
            <p class="show-loc">Xalapa, Veracruz</p>
          </div>
        </div>
        <div class="show-item show-item--placeholder">
          <span class="show-dot show-dot--muted"></span>
          <div>
            <p class="show-name show-name--muted">+ más fechas</p>
            <p class="show-loc">Historial completo bajo solicitud</p>
          </div>
        </div>
      </div>

      <p class="shows-note">
        * El historial completo de presentaciones se comparte bajo solicitud de booking.
      </p>
    </div>
  </section>
  <hr class="divider" />

  <section class="section">
    <div class="container">
      <span class="section-label">Material de prensa</span>
      <h2 class="section-heading">Descarga assets</h2>

      <div class="assets-grid">
        <div class="asset-card">
          <span class="asset-icon" aria-hidden="true">🖼</span>
          <p class="asset-name">Fotografías oficiales</p>
          <p class="asset-desc">
            Fotos de alta resolución para imprenta y medios digitales. Uso libre con crédito al grupo.
          </p>
          {
            photosUrl ? (
              <a href={photosUrl} class="asset-btn" target="_blank" rel="noopener noreferrer">
                ↓ Descargar
              </a>
            ) : (
              <span class="asset-btn--pending" aria-disabled="true">Próximamente</span>
            )
          }
        </div>
        <div class="asset-card">
          <span class="asset-icon" aria-hidden="true">◈</span>
          <p class="asset-name">Logotipo</p>
          <p class="asset-desc">PNG y SVG en versión oscura, clara y monocromática. Fondo transparente incluido.</p>
          {
            logoUrl ? (
              <a href={logoUrl} class="asset-btn" target="_blank" rel="noopener noreferrer">
                ↓ Descargar
              </a>
            ) : (
              <span class="asset-btn--pending" aria-disabled="true">Próximamente</span>
            )
          }
        </div>
        <div class="asset-card">
          <span class="asset-icon" aria-hidden="true">📄</span>
          <p class="asset-name">Bio corta (texto)</p>
          <p class="asset-desc">
            Versión de 80 palabras lista para programas, redes y comunicados de prensa.
          </p>
          {
            bioUrl ? (
              <a href={bioUrl} class="asset-btn" target="_blank" rel="noopener noreferrer">
                ↓ Descargar
              </a>
            ) : (
              <span class="asset-btn--pending" aria-disabled="true">Próximamente</span>
            )
          }
        </div>
        <div class="asset-card">
          <span class="asset-icon" aria-hidden="true">🎵</span>
          <p class="asset-name">Singles en streaming</p>
          <p class="asset-desc">
            Spotify, Apple Music y YouTube. También disponibles stems para radio bajo solicitud.
          </p>
          <a href={spotifyArtistUrl} target="_blank" rel="noopener noreferrer" class="asset-btn">→ Escuchar</a>
        </div>
      </div>
    </div>
  </section>

  <section class="booking section">
    <div class="container">
      <div>
        <p class="section-label">Contratar al grupo</p>
        <h2 class="booking-headline">
          ¿Tienes una<br /> <em>fecha disponible?</em>
        </h2>
        <p class="booking-sub">
          Respondemos cotizaciones en menos de 24 horas. Incluye fecha, ciudad y tipo de evento para agilizar la
          respuesta.
        </p>
      </div>
      <div class="booking-actions">
        <a href="/booking" class="btn-primary">Solicitar cotización</a>
        {
          whatsappUrl ? (
            <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary">
              WhatsApp directo
            </a>
          ) : null
        }
      </div>
    </div>
  </section>

  <footer class="footer-bar">
    <div class="container">
      <span class="footer-brand">La Mafia Tumbada</span>
      <p class="footer-copy">
        © {new Date().getFullYear()} · Xalapa, Veracruz · Todos los derechos reservados
      </p>
    </div>
  </footer>
</MarketingLayout>
