---
import MarketingLayout from '../layouts/MarketingLayout.astro'
import { formatBudgetLabel } from '../../../src/lib/bookingBudget'
import {
  BOOKING_PIPELINE_STATUS_VALUES,
  formatPipelineStatusLabel,
} from '../../../src/lib/bookingPipeline'
import { formatLeadPriorityLabel } from '../../../src/lib/bookingLeadScore'
import { normalizePublicApiBaseUrl } from '../lib/publicApiUrl'
import { adminCanonical } from '../lib/publicSiteUrl'
import { sanitizeResendDetail } from '../lib/sanitizeResendDetail'

const { isAuthenticated, redirectToSignIn, getToken } = Astro.locals.auth()

if (!isAuthenticated) {
  return redirectToSignIn({ returnBackUrl: '/admin' })
}

export const prerender = false

const adminCanonicalUrl = adminCanonical(import.meta.env.PUBLIC_SITE_URL, Astro.url.origin)
const apiUrl = normalizePublicApiBaseUrl(import.meta.env.PUBLIC_API_URL)
const resendParam = Astro.url.searchParams.get('resend')
let resendMessage: string | null = null
let resendIsOk = false
const resendDetail = sanitizeResendDetail(
  Astro.url.searchParams.get('resendDetail'),
)

if (resendParam === 'ok') {
  resendIsOk = true
  resendMessage = 'Confirmación reenviada con éxito.'
} else if (resendParam === 'error') {
  resendMessage = resendDetail
    ? `No se pudo reenviar la confirmación: ${resendDetail}`
    : 'No se pudo reenviar la confirmación.'
} else if (resendParam === 'invalid') {
  resendMessage = 'Solicitud inválida para reenviar confirmación.'
}

const pipelineParam = Astro.url.searchParams.get('pipeline')
let pipelineMessage: string | null = null
let pipelineIsOk = false
if (pipelineParam === 'ok') {
  pipelineIsOk = true
  pipelineMessage = 'Seguimiento actualizado.'
} else if (pipelineParam === 'error') {
  pipelineMessage = 'No se pudo actualizar el seguimiento. Intenta de nuevo.'
} else if (pipelineParam === 'invalid') {
  pipelineMessage = 'Solicitud inválida para actualizar seguimiento.'
}

let bookings: Array<{
  id: number
  name: string
  email: string
  phone: string | null
  eventDate: string | null
  budget: string | null
  leadScore: number | null
  leadPriority: string | null
  estimatedPriceRange: string
  message: string | null
  status: string
  pipelineStatus?: string | null
  confirmationLastError: string | null
  confirmationAttempts: number
  createdAt: number | Date
}> = []
let error: string | null = null
const pageSize = 50
const pageParam = Astro.url.searchParams.get('page')
const pageNum = Math.max(
  1,
  Number.parseInt(pageParam ?? '1', 10) || 1,
)
const page = Number.isFinite(pageNum) ? pageNum : 1
const offset = (page - 1) * pageSize
let totalBookings = 0
let hasMore = false

try {
  const token = await getToken()
  const listUrl = new URL(`${apiUrl}/api/admin/bookings`)
  listUrl.searchParams.set('limit', String(pageSize))
  listUrl.searchParams.set('offset', String(offset))
  const response = await fetch(listUrl.toString(), {
    headers: token ? { Authorization: `Bearer ${token}` } : {},
  })

  if (response.status === 401) {
    return redirectToSignIn({ returnBackUrl: '/admin' })
  }

  if (response.status === 403) {
    return new Response('', {
      status: 303,
      headers: { Location: '/' },
    })
  }

  if (!response.ok) {
    throw new Error(`API error: ${response.status}`)
  }

  const result = await response.json()
  bookings = result.data?.bookings ?? []
  totalBookings = typeof result.data?.total === 'number' ? result.data.total : 0
  hasMore = Boolean(result.data?.hasMore)

  const maxPage = Math.max(1, Math.ceil(totalBookings / pageSize))
  if (totalBookings > 0 && page > maxPage) {
    return Astro.redirect(`/admin?page=${maxPage}`)
  }
} catch (e) {
  error = e instanceof Error ? e.message : String(e)
  console.error('Failed to fetch bookings:', e)
}
---

<MarketingLayout
  title="Admin — Solicitudes de contratación"
  description="Panel interno de administración de solicitudes de contratación."
  canonicalUrl={adminCanonicalUrl}
  robots="noindex,nofollow"
>
  <section class="admin-page" aria-label="Solicitudes">
    <div class="container admin-container">
      <span class="section-label">Administración</span>
      <h1 class="admin-title">Solicitudes de contratación</h1>

      <p class="admin-actions">
        <a href="/admin/export-bookings" class="btn-secondary admin-export-btn">
          Exportar JSON (depuración)
        </a>
      </p>

    {resendMessage && (
      <div class={`resend-banner ${resendIsOk ? 'resend-ok' : 'resend-error'}`}>
        {resendMessage}
      </div>
    )}

    {pipelineMessage && (
      <div class={`resend-banner ${pipelineIsOk ? 'resend-ok' : 'resend-error'}`}>
        {pipelineMessage}
      </div>
    )}

    <div class="status-legend" role="note" aria-label="Correo vs seguimiento">
      <p>
        <strong>Columna Status (correo):</strong>{' '}
        <strong>sent</strong> = ambos correos enviados; <strong>pending</strong> = al cliente falló la
        confirmación; <strong>failed</strong> = falló el correo al equipo.
      </p>
      <p>
        <strong>Seguimiento:</strong> Nuevo / Contactado / Cerrado — independiente del envío de correo.
        Cambia con el menú; se guarda al elegir.
      </p>
    </div>

    {error && (
      <div class="error-message">
        Error al cargar solicitudes: {error}
      </div>
    )}

    {!error && totalBookings === 0 && (
      <p class="admin-empty">No hay solicitudes registradas.</p>
    )}

    {!error && totalBookings > 0 && (
      <p class="admin-pagination-meta">
        Showing {(page - 1) * pageSize + 1}–{Math.min(page * pageSize, totalBookings)} of {totalBookings}
 </p>
    )}

    {!error && bookings.length > 0 && (
      <div class="table-container">
        <table class="bookings-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Name</th>
              <th>Email</th>
              <th>Phone</th>
              <th>Event Date</th>
              <th class="sortable" data-sort="budget" scope="col">
                Budget <span class="sort-indicator" aria-hidden="true"></span>
              </th>
              <th>Prioridad</th>
              <th class="sortable" data-sort="leadScore" scope="col">
                Lead score <span class="sort-indicator" aria-hidden="true"></span>
              </th>
              <th>Est. Price</th>
              <th>Status</th>
              <th>Seguimiento</th>
                <th>Attempts</th>
                <th>Last confirmation error</th>
                <th>Operator</th>
              <th class="sortable" data-sort="created" scope="col">
                Created <span class="sort-indicator" aria-hidden="true"></span>
              </th>
            </tr>
          </thead>
          <tbody>
            {bookings.map((booking) => (
              <tr>
                <td>{booking.id}</td>
                <td>{booking.name}</td>
                <td>{booking.email}</td>
                <td>{booking.phone ?? '-'}</td>
                <td>{booking.eventDate ?? '-'}</td>
                <td data-cell="budget" data-budget={booking.budget ?? ''}>
                  {formatBudgetLabel(booking.budget)}
                </td>
                <td>{formatLeadPriorityLabel(booking.leadPriority)}</td>
                <td data-cell="leadScore" data-lead-score={booking.leadScore ?? ''}>
                  {booking.leadScore == null ? '-' : booking.leadScore}
                </td>
                <td>{booking.estimatedPriceRange ?? '-'}</td>
                <td>
                  <span class={`status-badge status-${booking.status}`}>
                    {booking.status}
                  </span>
                </td>
                <td>
                  <form method="post" action="/admin/update-pipeline" class="pipeline-form">
                    <input type="hidden" name="bookingId" value={booking.id} />
                    <select
                      name="pipelineStatus"
                      class="pipeline-select"
                      aria-label={`Seguimiento solicitud ${booking.id}`}
                      onchange="this.form.requestSubmit()"
                    >
                      {BOOKING_PIPELINE_STATUS_VALUES.map((v) => (
                        <option value={v} selected={(booking.pipelineStatus ?? 'new') === v}>
                          {formatPipelineStatusLabel(v)}
                        </option>
                      ))}
                    </select>
                  </form>
                </td>
                <td>
                  {booking.status === 'failed' ? '-' : booking.confirmationAttempts}
                </td>
                <td>
                  {booking.confirmationLastError ? (
                    <span title={booking.confirmationLastError}>
                      {booking.confirmationLastError.length > 80
                        ? `${booking.confirmationLastError.slice(0, 80)}...`
                        : booking.confirmationLastError}
                    </span>
                  ) : (
                    '-'
                  )}
                </td>
                <td>
                  {booking.status === 'pending' ? (
                    <form method="post" action="/admin/resend-confirmation" class="resend-form">
                      <input type="hidden" name="bookingId" value={booking.id} />
                      <button type="submit" class="resend-button">Re-send confirmation</button>
                    </form>
                  ) : (
                    '-'
                  )}
                </td>
                <td
                  data-cell="created"
                  data-timestamp={new Date(booking.createdAt).getTime()}
                >
                  {new Date(booking.createdAt).toLocaleDateString('es-MX')}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    {!error && totalBookings > pageSize && (
      <nav class="admin-pagination" aria-label="Booking pages">
        {page > 1 ? (
          <a href={`/admin?page=${page - 1}`} class="pagination-link">Previous</a>
        ) : (
          <span class="pagination-disabled">Previous</span>
        )}
        <span class="pagination-page">Page {page} of {Math.ceil(totalBookings / pageSize)}</span>
        {hasMore ? (
          <a href={`/admin?page=${page + 1}`} class="pagination-link">Next</a>
        ) : (
          <span class="pagination-disabled">Next</span>
        )}
      </nav>
    )}
    </div>
  </section>

  <footer class="footer-bar">
    <div class="container">
      <span class="footer-brand">Mafia Tumbada</span>
      <p class="footer-copy">
        © {new Date().getFullYear()} · Xalapa, Veracruz · Panel interno
      </p>
    </div>
  </footer>

  <script>
    import { BOOKING_BUDGET_SORT_RANK } from '../../../src/lib/bookingBudget'

    const budgetRanks = BOOKING_BUDGET_SORT_RANK

    ;(function () {
      const tbody = document.querySelector('.bookings-table tbody')
      if (!tbody) return
      const budgetTh = document.querySelector('.bookings-table th[data-sort="budget"]')
      const leadScoreTh = document.querySelector('.bookings-table th[data-sort="leadScore"]')
      const createdTh = document.querySelector('.bookings-table th[data-sort="created"]')
      let activeKey = null
      let activeDir = 'asc'

      function setIndicator(th, dir) {
        document.querySelectorAll('.bookings-table th[data-sort] .sort-indicator').forEach((el) => {
          el.textContent = ''
        })
        if (!th) return
        const span = th.querySelector('.sort-indicator')
        if (span) span.textContent = dir === 'asc' ? ' ▲' : ' ▼'
      }

      function sortBy(key) {
        const dir = activeKey === key && activeDir === 'asc' ? 'desc' : 'asc'
        activeKey = key
        activeDir = dir
        const rows = Array.from(tbody.querySelectorAll('tr'))
        const getVal =
          key === 'budget'
            ? (row) => {
                const td = row.querySelector('td[data-cell="budget"]')
                const b = td?.getAttribute('data-budget') ?? ''
                return budgetRanks[b] ?? 0
              }
            : key === 'leadScore'
              ? (row) => {
                  const td = row.querySelector('td[data-cell="leadScore"]')
                  const s = td?.getAttribute('data-lead-score') ?? ''
                  const n = s === '' ? 0 : Number(s)
                  return Number.isFinite(n) ? n : 0
                }
              : (row) => {
                  const td = row.querySelector('td[data-cell="created"]')
                  const t = td?.getAttribute('data-timestamp')
                  const n = t ? Number(t) : 0
                  return Number.isFinite(n) ? n : 0
                }
        rows.sort((a, b) => {
          const va = getVal(a)
          const vb = getVal(b)
          if (va === vb) return 0
          const cmp = va < vb ? -1 : 1
          return dir === 'asc' ? cmp : -cmp
        })
        rows.forEach((r) => tbody.appendChild(r))
        const activeTh =
          key === 'budget' ? budgetTh : key === 'leadScore' ? leadScoreTh : createdTh
        setIndicator(activeTh, dir)
      }

      budgetTh?.addEventListener('click', () => sortBy('budget'))
      leadScoreTh?.addEventListener('click', () => sortBy('leadScore'))
      createdTh?.addEventListener('click', () => sortBy('created'))
    })()
  </script>
</MarketingLayout>

<style>
  .admin-page {
    padding-block: clamp(5.5rem, 12vw, 7rem) clamp(2.5rem, 6vw, 4rem);
  }

  .admin-container {
    max-width: 1200px;
  }

  .admin-title {
    font-family: var(--ff-display, 'Cormorant Garamond', Georgia, serif);
    font-size: clamp(1.85rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.12;
    color: var(--text, #ede8df);
    margin: 0 0 1.25rem;
  }

  .admin-actions {
    margin-bottom: 1.5rem;
  }

  .admin-export-btn {
    display: inline-flex;
    width: fit-content;
  }

  .admin-empty {
    color: var(--muted, #7a7267);
    font-size: 0.95rem;
  }

  .admin-pagination-meta {
    margin: 0 0 0.75rem;
    font-size: 0.875rem;
    color: var(--muted, #7a7267);
  }

  .admin-pagination {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.25rem;
    flex-wrap: wrap;
  }

  .pagination-link {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold, #c49a2a);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s, color 0.2s;
  }

  .pagination-link:hover {
    border-bottom-color: var(--gold-dim, #8a6c1c);
    color: var(--gold-dim, #8a6c1c);
  }

  .pagination-disabled {
    font-size: 0.8rem;
    color: var(--muted, #7a7267);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .pagination-page {
    font-size: 0.85rem;
    color: var(--muted, #7a7267);
  }

  .error-message {
    background: var(--surface2, #191919);
    border: 1px solid #5c2a2a;
    color: #f0c4c4;
    padding: 1rem 1.1rem;
    border-radius: 0.25rem;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .resend-banner {
    margin: 1rem 0;
    padding: 0.75rem 1rem;
    border-radius: 0.25rem;
    border: 1px solid var(--border, #262420);
    font-size: 0.9rem;
  }

  .resend-ok {
    background: rgba(34, 80, 56, 0.35);
    border-color: rgba(196, 154, 42, 0.45);
    color: #d8e8df;
  }

  .resend-error {
    background: rgba(60, 24, 24, 0.45);
    border-color: rgba(180, 90, 90, 0.5);
    color: #f0d4d4;
  }

  .status-legend {
    margin: 1rem 0 1.5rem;
    padding: 1rem 1.15rem;
    background: var(--surface, #111111);
    border: 1px solid var(--border, #262420);
    border-radius: 0.25rem;
  }

  .status-legend p {
    margin: 0.35rem 0;
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--muted, #7a7267);
  }

  .status-legend strong {
    color: var(--text, #ede8df);
    font-weight: 600;
  }

  .table-container {
    overflow-x: auto;
    border: 1px solid var(--border, #262420);
    border-radius: 0.25rem;
    background: var(--surface, #111111);
  }

  .bookings-table {
    width: 100%;
    min-width: 720px;
    border-collapse: collapse;
    background: var(--surface, #111111);
    color: var(--text, #ede8df);
    font-size: 0.8125rem;
  }

  .bookings-table th,
  .bookings-table td {
    padding: 0.65rem 0.75rem;
    text-align: left;
    border-bottom: 1px solid var(--border, #262420);
    vertical-align: top;
  }

  .bookings-table tbody tr:hover {
    background: var(--surface2, #191919);
  }

  .bookings-table th {
    background: var(--bg, #0b0b0b);
    font-family: var(--ff-body, system-ui, sans-serif);
    font-weight: 600;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold, #c49a2a);
    white-space: nowrap;
  }

  .bookings-table th.sortable {
    cursor: pointer;
    user-select: none;
  }

  .bookings-table th.sortable:hover {
    background: var(--surface2, #191919);
    color: var(--text, #ede8df);
  }

  .sort-indicator {
    font-size: 0.65rem;
    color: var(--gold, #c49a2a);
  }

  .status-badge {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    border-radius: 9999px;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid transparent;
  }

  .status-pending {
    background: rgba(196, 154, 42, 0.18);
    border-color: rgba(196, 154, 42, 0.45);
    color: #e8d4a8;
  }

  .status-sent {
    background: rgba(46, 120, 80, 0.28);
    border-color: rgba(80, 160, 110, 0.45);
    color: #c5e8d4;
  }

  .status-failed {
    background: rgba(120, 40, 40, 0.35);
    border-color: rgba(200, 100, 100, 0.45);
    color: #f0c8c8;
  }

  .resend-form,
  .pipeline-form {
    margin: 0;
  }

  .pipeline-select {
    font-size: 0.8125rem;
    max-width: 11rem;
    color-scheme: dark;
    color: var(--text, #ede8df);
    background: var(--bg, #0b0b0b);
    border: 1px solid var(--border, #262420);
    border-radius: 0.2rem;
    padding: 0.3rem 0.45rem;
  }

  .resend-button {
    font-family: var(--ff-body, system-ui, sans-serif);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold, #c49a2a);
    background: transparent;
    border: 1px solid var(--gold-dim, #8a6c1c);
    padding: 0.4rem 0.65rem;
    border-radius: 0.15rem;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  .resend-button:hover {
    border-color: var(--gold, #c49a2a);
    color: var(--text, #ede8df);
    background: rgba(196, 154, 42, 0.12);
  }
</style>
