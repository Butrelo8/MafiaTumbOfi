---
import MarketingLayout from '../layouts/MarketingLayout.astro'
import { formatBudgetLabel } from '../../../src/lib/bookingBudget'
import {
  BOOKING_PIPELINE_STATUS_VALUES,
  formatPipelineStatusLabel,
} from '../../../src/lib/bookingPipeline'
import { formatLeadPriorityLabel } from '../../../src/lib/bookingLeadScore'
import { normalizePublicApiBaseUrl } from '../lib/publicApiUrl'
import { adminCanonical } from '../lib/publicSiteUrl'
import { sanitizeResendDetail } from '../lib/sanitizeResendDetail'
import {
  leadPriorityCountsForAdminRows,
  pipelineCountsForAdminRows,
} from '../lib/adminPipelinePageCounts'
import { phoneToTelHref } from '../lib/adminQuickActions'
import { staleNewBadgeState } from '../lib/adminStaleNewBadge'

const { isAuthenticated, redirectToSignIn, getToken } = Astro.locals.auth()

if (!isAuthenticated) {
  return redirectToSignIn({ returnBackUrl: '/admin' })
}

export const prerender = false

const adminCanonicalUrl = adminCanonical(import.meta.env.PUBLIC_SITE_URL, Astro.url.origin)
const apiUrl = normalizePublicApiBaseUrl(import.meta.env.PUBLIC_API_URL)
const resendParam = Astro.url.searchParams.get('resend')
let resendMessage: string | null = null
let resendIsOk = false
const resendDetail = sanitizeResendDetail(
  Astro.url.searchParams.get('resendDetail'),
)

if (resendParam === 'ok') {
  resendIsOk = true
  resendMessage = 'Confirmación reenviada con éxito.'
} else if (resendParam === 'error') {
  resendMessage = resendDetail
    ? `No se pudo reenviar la confirmación: ${resendDetail}`
    : 'No se pudo reenviar la confirmación.'
} else if (resendParam === 'invalid') {
  resendMessage = 'Solicitud inválida para reenviar confirmación.'
}

const pipelineParam = Astro.url.searchParams.get('pipeline')
let pipelineMessage: string | null = null
let pipelineIsOk = false
if (pipelineParam === 'ok') {
  pipelineIsOk = true
  pipelineMessage = 'Seguimiento actualizado.'
} else if (pipelineParam === 'error') {
  pipelineMessage = 'No se pudo actualizar el seguimiento. Intenta de nuevo.'
} else if (pipelineParam === 'invalid') {
  pipelineMessage = 'Solicitud inválida para actualizar seguimiento.'
}

const bulkDeletedParam = Astro.url.searchParams.get('bulkDeleted')
const bulkDeletedCountRaw = Astro.url.searchParams.get('count')
let bulkDeletedMessage: string | null = null
let bulkDeletedIsOk = false
if (bulkDeletedParam === 'ok') {
  bulkDeletedIsOk = true
  const nParsed =
    bulkDeletedCountRaw != null ? Number.parseInt(bulkDeletedCountRaw, 10) : Number.NaN
  bulkDeletedMessage = Number.isFinite(nParsed)
    ? `Base vaciada: ${nParsed} registro(s) eliminado(s) por completo (incluye ocultos por soft-delete).`
    : 'Base vaciada: todas las solicitudes eliminadas por completo.'
}

type AdminBookingRow = {
  id: number
  name: string
  email: string
  phone: string | null
  city: string | null
  eventDate: string | null
  budget: string | null
  leadScore: number | null
  leadPriority: string | null
  estimatedPriceRange: string
  message: string | null
  status: string
  pipelineStatus?: string | null
  internalNotes?: string | null
  confirmationLastError: string | null
  confirmationAttempts: number
  createdAt: number | Date
}

let bookings: AdminBookingRow[] = []
let error: string | null = null
const pageSize = 50
const pageParam = Astro.url.searchParams.get('page')
const pageNum = Math.max(
  1,
  Number.parseInt(pageParam ?? '1', 10) || 1,
)
const page = Number.isFinite(pageNum) ? pageNum : 1
const offset = (page - 1) * pageSize
let totalBookings = 0
let hasMore = false

try {
  const token = await getToken()
  const listUrl = new URL(`${apiUrl}/api/admin/bookings`)
  listUrl.searchParams.set('limit', String(pageSize))
  listUrl.searchParams.set('offset', String(offset))
  const response = await fetch(listUrl.toString(), {
    headers: token ? { Authorization: `Bearer ${token}` } : {},
  })

  if (response.status === 401) {
    return redirectToSignIn({ returnBackUrl: '/admin' })
  }

  if (response.status === 403) {
    return new Response('', {
      status: 303,
      headers: { Location: '/' },
    })
  }

  if (!response.ok) {
    throw new Error(`API error: ${response.status}`)
  }

  const result = await response.json()
  bookings = result.data?.bookings ?? []
  totalBookings = typeof result.data?.total === 'number' ? result.data.total : 0
  hasMore = Boolean(result.data?.hasMore)

  const maxPage = Math.max(1, Math.ceil(totalBookings / pageSize))
  if (totalBookings > 0 && page > maxPage) {
    return Astro.redirect(`/admin?page=${maxPage}`)
  }
} catch (e) {
  error = e instanceof Error ? e.message : String(e)
  console.error('Failed to fetch bookings:', e)
}

type AdminTourRow = {
  id: number
  date: string
  time: string | null
  city: string
  venue: string
  status: 'confirmed' | 'tentative' | 'cancelled'
  ticketUrl: string | null
  soldOut: boolean
  notes: string | null
}

let adminTours: AdminTourRow[] = []
let toursError: string | null = null

try {
  const tokenTours = await getToken()
  const toursUrl = `${apiUrl}/api/admin/tours`
  const toursRes = await fetch(toursUrl, {
    headers: tokenTours ? { Authorization: `Bearer ${tokenTours}` } : {},
  })

  if (toursRes.status === 401) {
    return redirectToSignIn({ returnBackUrl: '/admin' })
  }

  if (toursRes.status === 403) {
    return new Response('', {
      status: 303,
      headers: { Location: '/' },
    })
  }

  if (!toursRes.ok) {
    toursError = `API error: ${toursRes.status}`
  } else {
    const tr = (await toursRes.json()) as { data?: unknown }
    const data = tr.data
    adminTours = Array.isArray(data) ? (data as AdminTourRow[]) : []
  }
} catch (e) {
  toursError = e instanceof Error ? e.message : String(e)
  console.error('Failed to fetch admin tours:', e)
}

const pipeCounts = pipelineCountsForAdminRows(bookings)
const priorityCounts = leadPriorityCountsForAdminRows(bookings)

function leadPriorityBadgeClass(p: string | null | undefined): string {
  const base = 'admin-priority-badge'
  if (p === 'high') return `${base} admin-priority-high`
  if (p === 'medium') return `${base} admin-priority-medium`
  if (p === 'low') return `${base} admin-priority-low`
  return `${base} admin-priority-unknown`
}
const nowMs = Date.now()
const bookingsJson = JSON.stringify(bookings).replace(/</g, '\\u003c')
const adminToursJson = JSON.stringify(adminTours).replace(/</g, '\\u003c')
---

<MarketingLayout
  title="Admin — Solicitudes de contratación"
  description="Panel interno de administración de solicitudes de contratación."
  canonicalUrl={adminCanonicalUrl}
  robots="noindex,nofollow"
>
  <section class="admin-page" aria-label="Solicitudes">
    <div class="container admin-container">
      <span class="section-label">Administración</span>
      <h1 class="admin-title">Solicitudes de contratación</h1>

      <p class="admin-actions">
        <button type="button" id="admin-export-csv" class="btn-secondary admin-export-btn">
          Descargar CSV (página visible)
        </button>
        <a href="/admin/export-bookings" class="btn-secondary admin-export-btn">
          Exportar JSON (depuración)
        </a>
      </p>

      <div class="admin-tabs" role="tablist" aria-label="Secciones del panel">
        <button
          type="button"
          class="admin-tab is-active"
          role="tab"
          aria-selected="true"
          aria-controls="solicitudes-panel"
          id="admin-tab-solicitudes"
          data-tab="solicitudes"
        >
          Solicitudes ({totalBookings})
        </button>
        <button
          type="button"
          class="admin-tab"
          role="tab"
          aria-selected="false"
          aria-controls="fechas-panel"
          id="admin-tab-fechas"
          data-tab="fechas"
        >
          Fechas ({adminTours.length})
        </button>
      </div>

      <div id="solicitudes-panel" class="admin-tab-panel" role="tabpanel" aria-labelledby="admin-tab-solicitudes">

    {resendMessage && (
      <div class={`resend-banner ${resendIsOk ? 'resend-ok' : 'resend-error'}`}>
        {resendMessage}
      </div>
    )}

    {pipelineMessage && (
      <div class={`resend-banner ${pipelineIsOk ? 'resend-ok' : 'resend-error'}`}>
        {pipelineMessage}
      </div>
    )}

    {bulkDeletedMessage && (
      <div class={`resend-banner ${bulkDeletedIsOk ? 'resend-ok' : 'resend-error'}`}>
        {bulkDeletedMessage}
      </div>
    )}

    <div class="status-legend" role="note" aria-label="Leyenda del panel">
      <p>
        <strong>Status (correo):</strong>{' '}
        <strong>sent</strong> = confirmación ok; <strong>pending</strong> = falló al cliente;{' '}
        <strong>failed</strong> = falló al equipo.
      </p>
      <p>
        <strong>Seguimiento:</strong> Nuevo / Contactado / Cerrado — independiente del correo. El menú guarda al elegir.
      </p>
      <p>
        <strong>CSV:</strong> exporta las filas visibles en esta página (filtros de búsqueda y pastillas aplicados).
      </p>
      <p>
        <strong>Eliminar:</strong> oculta la solicitud del panel (soft-delete); no borra el historial en base de datos.
      </p>
    </div>

    <div class="admin-danger-zone" aria-labelledby="admin-danger-title">
      <h2 id="admin-danger-title" class="admin-danger-title">
        Zona peligrosa
      </h2>
      <p class="admin-danger-copy">
        <strong>Borrar todas las solicitudes</strong> elimina por completo cada fila de la tabla{' '}
        <code>bookings</code> (incluye las ocultas por soft-delete). No se puede deshacer desde el panel. En
        producción la API debe tener{' '}
        <code>ALLOW_ADMIN_DELETE_ALL_BOOKINGS=true</code> (o entorno de desarrollo).
      </p>
      <button type="button" class="btn-secondary admin-danger-open" id="admin-open-delete-all">
        Vaciar todas las solicitudes…
      </button>
    </div>

    <div id="admin-delete-all-modal" class="admin-drawer" hidden>
      <div class="admin-drawer-backdrop" data-close-delete-all-modal aria-hidden="true"></div>
      <div
        class="admin-drawer-panel admin-delete-all-panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="admin-delete-all-modal-title"
      >
        <div class="admin-drawer-head">
          <h2 id="admin-delete-all-modal-title" class="admin-drawer-title">
            Borrar todas las solicitudes
          </h2>
          <button type="button" class="admin-drawer-close" data-close-delete-all-modal>
            Cerrar
          </button>
        </div>
        <p class="admin-danger-modal-intro">
          Escribe exactamente la frase (mayúsculas y guion bajo) para habilitar el borrado definitivo:
        </p>
        <p>
          <code class="admin-code-phrase">DELETE_ALL_BOOKINGS</code>
        </p>
        <label class="admin-delete-all-label" for="admin-delete-all-phrase">
          Frase de confirmación
        </label>
        <input
          id="admin-delete-all-phrase"
          class="admin-delete-all-input"
          type="text"
          autocomplete="off"
          spellcheck="false"
        />
        <div class="admin-delete-all-actions">
          <button type="button" class="btn-secondary" id="admin-delete-all-dry">
            Vista previa (conteo)
          </button>
          <button type="button" class="admin-delete-btn" id="admin-delete-all-submit" disabled>
            Borrar todo (irreversible)
          </button>
        </div>
        <p id="admin-delete-all-dry-result" class="admin-danger-feedback" hidden></p>
        <p id="admin-delete-all-modal-error" class="admin-danger-feedback admin-danger-error" hidden></p>
      </div>
    </div>

    {error && (
      <div class="error-message">
        Error al cargar solicitudes: {error}
      </div>
    )}

    {!error && totalBookings === 0 && (
      <p class="admin-empty">No hay solicitudes registradas.</p>
    )}

    {!error && totalBookings > 0 && (
      <p class="admin-pagination-meta">
        Mostrando {(page - 1) * pageSize + 1}–{Math.min(page * pageSize, totalBookings)} de {totalBookings}
      </p>
    )}

    {!error && bookings.length > 0 && (
      <>
        <div class="admin-toolbar" aria-label="Filtros de la página actual">
          <label class="admin-search-label">
            <span class="admin-search-text">Buscar</span>
            <input
              id="admin-booking-search"
              type="search"
              class="admin-search-input"
              placeholder="Nombre, correo o teléfono…"
              autocomplete="off"
            />
          </label>
          <div id="admin-bookings-toolbar" class="admin-bookings-toolbar">
            <div class="admin-pipeline-pills" role="toolbar" aria-label="Filtrar por seguimiento">
              <button type="button" class="admin-pill is-active" data-pipeline-filter="all">
                Todas ({bookings.length})
              </button>
              <button type="button" class="admin-pill" data-pipeline-filter="new">
                Nuevo ({pipeCounts.new})
              </button>
              <button type="button" class="admin-pill" data-pipeline-filter="contacted">
                Contactado ({pipeCounts.contacted})
              </button>
              <button type="button" class="admin-pill" data-pipeline-filter="closed">
                Cerrado ({pipeCounts.closed})
              </button>
            </div>
            <div class="admin-priority-pills admin-pipeline-pills" role="toolbar" aria-label="Filtrar por prioridad de lead">
              <button type="button" class="admin-pill is-active" data-priority-filter="all">
                Prioridad: todas ({bookings.length})
              </button>
              <button type="button" class="admin-pill" data-priority-filter="high">
                Alta ({priorityCounts.high})
              </button>
              <button type="button" class="admin-pill" data-priority-filter="medium">
                Media ({priorityCounts.medium})
              </button>
              <button type="button" class="admin-pill" data-priority-filter="low">
                Baja ({priorityCounts.low})
              </button>
            </div>
          </div>
        </div>

        <div class="table-container">
          <table class="bookings-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Correo</th>
                <th>Teléfono</th>
                <th>Ciudad</th>
                <th class="sortable" data-sort="eventDate" scope="col">
                  Fecha evento <span class="sort-indicator" aria-hidden="true"></span>
                </th>
                <th class="sortable" data-sort="budget" scope="col">
                  Presupuesto <span class="sort-indicator" aria-hidden="true"></span>
                </th>
                <th>Prioridad</th>
                <th class="sortable" data-sort="leadScore" scope="col">
                  Lead <span class="sort-indicator" aria-hidden="true"></span>
                </th>
                <th>Est. precio</th>
                <th>Status</th>
                <th>Seguimiento</th>
                <th>Intentos</th>
                <th>Error confirm.</th>
                <th>Notas</th>
                <th>Acciones</th>
                <th class="sortable" data-sort="created" scope="col">
                  Creado <span class="sort-indicator" aria-hidden="true"></span>
                </th>
              </tr>
            </thead>
            <tbody>
              {bookings.map((booking) => {
                const pipelineKey = booking.pipelineStatus ?? 'new'
                const createdMs = new Date(booking.createdAt).getTime()
                const stale = staleNewBadgeState(pipelineKey, createdMs, nowMs)
                const tel = phoneToTelHref(booking.phone)
                const notesPreview =
                  booking.internalNotes && booking.internalNotes.trim() !== ''
                    ? booking.internalNotes.length > 40
                      ? `${booking.internalNotes.slice(0, 40)}…`
                      : booking.internalNotes
                    : '—'
                return (
                  <tr
                    key={booking.id}
                    class="admin-booking-row"
                    data-row-id={booking.id}
                    data-pipeline-status={pipelineKey}
                    data-lead-priority={booking.leadPriority ?? ''}
                  >
                    <td>{booking.id}</td>
                    <td>{booking.name}</td>
                    <td>{booking.email}</td>
                    <td>
                      {tel ? (
                        <a href={tel} class="admin-tel-link">{booking.phone ?? '—'}</a>
                      ) : (
                        (booking.phone ?? '—')
                      )}
                    </td>
                    <td>{booking.city ?? '—'}</td>
                    <td data-cell="eventDate" data-event-date={booking.eventDate ?? ''}>
                      {booking.eventDate ?? '—'}
                    </td>
                    <td data-cell="budget" data-budget={booking.budget ?? ''}>
                      {formatBudgetLabel(booking.budget)}
                    </td>
                    <td data-cell="leadPriority">
                      <span class={leadPriorityBadgeClass(booking.leadPriority)}>
                        {formatLeadPriorityLabel(booking.leadPriority)}
                      </span>
                    </td>
                    <td data-cell="leadScore" data-lead-score={booking.leadScore ?? ''}>
                      {booking.leadScore == null ? '—' : booking.leadScore}
                    </td>
                    <td>{booking.estimatedPriceRange ?? '—'}</td>
                    <td>
                      <span class={`status-badge status-${booking.status}`}>
                        {booking.status}
                      </span>
                    </td>
                    <td>
                      <div class="admin-pipeline-cell">
                        {stale && (
                          <span
                            class={`admin-stale-badge admin-stale-${stale.severity}`}
                            title={`${stale.days} días en Nuevo`}
                          >
                            {stale.days}d
                          </span>
                        )}
                        <form method="post" action="/admin/update-pipeline" class="pipeline-form">
                          <input type="hidden" name="bookingId" value={booking.id} />
                          <select
                            name="pipelineStatus"
                            class="pipeline-select"
                            aria-label={`Seguimiento solicitud ${booking.id}`}
                            onchange="this.form.requestSubmit()"
                            value={pipelineKey}
                          >
                            {BOOKING_PIPELINE_STATUS_VALUES.map((v) => (
                              <option value={v}>{formatPipelineStatusLabel(v)}</option>
                            ))}
                          </select>
                        </form>
                      </div>
                    </td>
                    <td>
                      {booking.status === 'failed' ? '—' : booking.confirmationAttempts}
                    </td>
                    <td>
                      {booking.confirmationLastError ? (
                        <span title={booking.confirmationLastError}>
                          {booking.confirmationLastError.length > 80
                            ? `${booking.confirmationLastError.slice(0, 80)}…`
                            : booking.confirmationLastError}
                        </span>
                      ) : (
                        '—'
                      )}
                    </td>
                    <td class="admin-notes-preview" title={booking.internalNotes ?? ''}>
                      {notesPreview}
                    </td>
                    <td class="admin-actions-cell">
                      <div class="admin-actions-stack">
                        <button
                          type="button"
                          class="admin-linkish"
                          data-open-drawer={booking.id}
                        >
                          Ver detalle
                        </button>
                        {booking.status === 'pending' ? (
                          <form method="post" action="/admin/resend-confirmation" class="resend-form">
                            <input type="hidden" name="bookingId" value={booking.id} />
                            <button type="submit" class="resend-button">Reenviar confirmación</button>
                          </form>
                        ) : null}
                        <button
                          type="button"
                          class="admin-delete-btn"
                          data-soft-delete={booking.id}
                        >
                          Eliminar
                        </button>
                      </div>
                    </td>
                    <td
                      data-cell="created"
                      data-timestamp={createdMs}
                    >
                      {new Date(booking.createdAt).toLocaleDateString('es-MX')}
                    </td>
                  </tr>
                )
              })}
            </tbody>
          </table>
        </div>
      </>
    )}

    {!error && totalBookings > pageSize && (
      <nav class="admin-pagination" aria-label="Paginación">
        {page > 1 ? (
          <a href={`/admin?page=${page - 1}`} class="pagination-link">Anterior</a>
        ) : (
          <span class="pagination-disabled">Anterior</span>
        )}
        <span class="pagination-page">Página {page} de {Math.ceil(totalBookings / pageSize)}</span>
        {hasMore ? (
          <a href={`/admin?page=${page + 1}`} class="pagination-link">Siguiente</a>
        ) : (
          <span class="pagination-disabled">Siguiente</span>
        )}
      </nav>
    )}
    </div>

    <section
      id="fechas-panel"
      class="admin-tab-panel fechas-panel"
      role="tabpanel"
      aria-labelledby="admin-tab-fechas"
      hidden
      data-tours-error={toursError ?? ''}
    >
      <div class="fechas-source-card">
        <p>
          <strong>Fuente:</strong> tabla <code>tour_dates</code> (API <code>/api/admin/tours</code>)
        </p>
      </div>

      {toursError && (
        <div class="fechas-fallback-banner" role="alert">
          Error al cargar fechas: {toursError}
        </div>
      )}

      {!toursError && adminTours.length === 0 && (
        <p class="fechas-empty-banner">
          No hay fechas en la base. El sitio público mostrará el calendario vacío hasta que agregues fechas aquí.
        </p>
      )}

      <div id="fechas-next-show" class="fechas-next-show" hidden></div>

      <div class="fechas-toolbar">
        <div class="admin-pipeline-pills fechas-filter-pills" role="toolbar" aria-label="Filtrar fechas">
          <button type="button" class="admin-pill is-active" data-fechas-filter="upcoming">
            Próximas (<span id="fechas-count-upcoming">0</span>)
          </button>
          <button type="button" class="admin-pill" data-fechas-filter="past">
            Pasadas (<span id="fechas-count-past">0</span>)
          </button>
          <button type="button" class="admin-pill" data-fechas-filter="all">
            Todas (<span id="fechas-count-all">0</span>)
          </button>
        </div>
        <div class="fechas-toolbar-actions">
          <button type="button" class="btn-primary" id="fechas-add-open">
            Agregar fecha
          </button>
          <button type="button" class="btn-secondary" id="fechas-refresh">
            Recargar
          </button>
        </div>
      </div>

      <div class="table-container">
        <table class="fechas-table" aria-label="Fechas de gira">
          <thead>
            <tr>
              <th>Fecha</th>
              <th>Hora</th>
              <th>Ciudad</th>
              <th>Venue</th>
              <th>Estado</th>
              <th>Enlace</th>
              <th>Notas</th>
            </tr>
          </thead>
          <tbody id="fechas-tbody"></tbody>
        </table>
      </div>

      <dialog id="fechas-add-dialog" class="fechas-add-dialog">
        <form id="fechas-add-form" novalidate>
          <h3 class="fechas-add-title">Nueva fecha</h3>
          <p id="fechas-add-error" class="fechas-add-error" role="alert" hidden></p>
          <div class="fechas-add-grid">
            <label class="fechas-add-field">
              Fecha
              <input type="date" name="date" required />
            </label>
            <label class="fechas-add-field">
              Hora
              <input type="text" name="time" placeholder="ej. 21:00" maxlength="32" autocomplete="off" />
            </label>
            <label class="fechas-add-field">
              Ciudad
              <input type="text" name="city" required maxlength="200" autocomplete="off" />
            </label>
            <label class="fechas-add-field">
              Venue
              <input type="text" name="venue" required maxlength="300" autocomplete="off" />
            </label>
            <label class="fechas-add-field">
              Estado
              <select name="status">
                <option value="confirmed">Confirmada</option>
                <option value="tentative">Tentativa</option>
                <option value="cancelled">Cancelada</option>
              </select>
            </label>
            <label class="fechas-add-field fechas-add-field--wide">
              Enlace boletos (opcional)
              <input type="url" name="ticketUrl" placeholder="https://…" />
            </label>
            <label class="fechas-add-field fechas-add-check">
              <input type="checkbox" name="soldOut" />
              Agotado
            </label>
            <label class="fechas-add-field fechas-add-field--wide">
              Notas internas
              <textarea name="notes" rows="3" maxlength="10000"></textarea>
            </label>
          </div>
          <div class="fechas-add-actions">
            <button type="button" class="btn-secondary" id="fechas-add-cancel">
              Cancelar
            </button>
            <button type="submit" class="btn-primary" id="fechas-add-submit">Guardar</button>
          </div>
        </form>
      </dialog>
    </section>
    </div>
  </section>

  <div id="admin-drawer" class="admin-drawer" hidden>
    <div class="admin-drawer-backdrop" data-close-drawer aria-hidden="true"></div>
    <div
      class="admin-drawer-panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby="admin-drawer-title"
    >
      <div class="admin-drawer-head">
        <h2 id="admin-drawer-title" class="admin-drawer-title">Detalle de solicitud</h2>
        <button type="button" class="admin-drawer-close" data-close-drawer>
          Cerrar
        </button>
