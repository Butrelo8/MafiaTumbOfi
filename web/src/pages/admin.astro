  <script is:inline type="application/json" id="admin-bookings-json" set:html={bookingsJson} />
  <script is:inline type="application/json" id="admin-tours-json" set:html={adminToursJson} />

  <script is:inline>
    ;(function () {
      var solicitudesPanel = document.getElementById('solicitudes-panel')
      var fechasPanel = document.getElementById('fechas-panel')
      var tabSolicitudes = document.getElementById('admin-tab-solicitudes')
      var tabFechas = document.getElementById('admin-tab-fechas')
      if (!solicitudesPanel || !fechasPanel || !tabSolicitudes || !tabFechas) return

      function setTab(name) {
        var isSol = name === 'solicitudes'
        solicitudesPanel.hidden = !isSol
        fechasPanel.hidden = isSol
        tabSolicitudes.classList.toggle('is-active', isSol)
        tabFechas.classList.toggle('is-active', !isSol)
        tabSolicitudes.setAttribute('aria-selected', isSol ? 'true' : 'false')
        tabFechas.setAttribute('aria-selected', isSol ? 'false' : 'true')
      }
      tabSolicitudes.addEventListener('click', function () {
        setTab('solicitudes')
      })
      tabFechas.addEventListener('click', function () {
        setTab('fechas')
      })

      function todayIso() {
        var d = new Date()
        var y = d.getFullYear()
        var m = String(d.getMonth() + 1).padStart(2, '0')
        var day = String(d.getDate()).padStart(2, '0')
        return y + '-' + m + '-' + day
      }

      var rows = []
      var filter = 'upcoming'

      function readToursFromDom() {
        var el = document.getElementById('admin-tours-json')
        if (!el || !el.textContent) return []
        try {
          return JSON.parse(el.textContent)
        } catch {
          return []
        }
      }

      function filtered() {
        var t = todayIso()
        if (filter === 'all') return rows.slice()
        return rows.filter(function (r) {
          return filter === 'past' ? r.date < t : r.date >= t
        })
      }

      function renderCounts() {
        var t = todayIso()
        var up = rows.filter(function (r) {
          return r.date >= t
        }).length
        var past = rows.filter(function (r) {
          return r.date < t
        }).length
        var elUp = document.getElementById('fechas-count-upcoming')
        var elPast = document.getElementById('fechas-count-past')
        var elAll = document.getElementById('fechas-count-all')
        if (elUp) elUp.textContent = String(up)
        if (elPast) elPast.textContent = String(past)
        if (elAll) elAll.textContent = String(rows.length)
      }

      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, function (c) {
          return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] || c
        })
      }

      function renderNextShow() {
        var box = document.getElementById('fechas-next-show')
        if (!box) return
        var t = todayIso()
        var upcoming = rows
          .filter(function (r) {
            return r.date >= t && r.status !== 'cancelled'
          })
          .sort(function (a, b) {
            return a.date.localeCompare(b.date)
          })
        var next = upcoming[0]
        if (!next) {
          box.hidden = true
          box.innerHTML = ''
          return
        }
        var d0 = new Date(next.date + 'T12:00:00')
        var days = Math.max(0, Math.ceil((d0.getTime() - Date.now()) / 86400000))
        box.hidden = false
        box.innerHTML =
          '<div class="fechas-next-card"><p class="fechas-next-label">Próximo show</p><p class="fechas-next-title">' +
          escapeHtml(next.city) +
          ' · ' +
          escapeHtml(next.venue) +
          '</p><p class="fechas-next-meta">' +
          escapeHtml(next.date) +
          (next.time ? ' · ' + escapeHtml(next.time) : '') +
          '</p><p class="fechas-next-countdown">En ' +
          days +
          ' día(s)</p></div>'
      }

      function renderTable() {
        var tbody = document.getElementById('fechas-tbody')
        if (!tbody) return
        tbody.replaceChildren()
        var list = filtered()
        for (var i = 0; i < list.length; i++) {
          var r = list[i]
          var tr = document.createElement('tr')
          var ticketCell = r.ticketUrl
            ? '<button type="button" class="admin-linkish fechas-copy" data-url="' +
              escapeHtml(r.ticketUrl) +
              '">Copiar enlace</button>'
            : '—'
          tr.innerHTML =
            '<td>' +
            escapeHtml(r.date) +
            '</td><td>' +
            (r.time ? escapeHtml(r.time) : '—') +
            '</td><td>' +
            escapeHtml(r.city) +
            '</td><td>' +
            escapeHtml(r.venue) +
            '</td><td><span class="fechas-status fechas-status-' +
            escapeHtml(r.status) +
            '">' +
            escapeHtml(r.status) +
            '</span></td><td>' +
            ticketCell +
            '</td><td class="fechas-notes">' +
            (r.notes
              ? escapeHtml(r.notes.length > 80 ? r.notes.slice(0, 80) + '…' : r.notes)
              : '—') +
            '</td>'
          tbody.appendChild(tr)
        }
        tbody.querySelectorAll('.fechas-copy').forEach(function (btn) {
          btn.addEventListener('click', async function () {
            var url = btn.getAttribute('data-url')
            if (!url) return
            try {
              await navigator.clipboard.writeText(url)
              alert('Enlace copiado')
            } catch {
              window.prompt('Copiar enlace:', url)
            }
          })
        })
      }

      function fullRender() {
        rows = readToursFromDom()
        renderCounts()
        renderNextShow()
        renderTable()
      }

      document.querySelectorAll('[data-fechas-filter]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          filter = btn.getAttribute('data-fechas-filter') || 'upcoming'
          document.querySelectorAll('[data-fechas-filter]').forEach(function (b) {
            b.classList.toggle('is-active', b === btn)
          })
          renderTable()
        })
      })

      async function refreshToursFromServer() {
        try {
          var res = await fetch('/admin/tours')
          var j = await res.json()
          if (!res.ok) {
            alert((j && j.error && j.error.message) || 'Error')
            return false
          }
          var data = j.data
          if (!Array.isArray(data)) return false
          var el = document.getElementById('admin-tours-json')
          if (el) el.textContent = JSON.stringify(data)
          rows = data
          renderCounts()
          renderNextShow()
          renderTable()
          if (tabFechas) tabFechas.textContent = 'Fechas (' + data.length + ')'
          return true
        } catch {
          alert('Error de red')
          return false
        }
      }

      document.getElementById('fechas-refresh')?.addEventListener('click', function () {
        refreshToursFromServer()
      })

      var addDialog = document.getElementById('fechas-add-dialog')
      var addForm = document.getElementById('fechas-add-form')
      var addError = document.getElementById('fechas-add-error')
      var addSubmit = document.getElementById('fechas-add-submit')

      document.getElementById('fechas-add-open')?.addEventListener('click', function () {
        if (addError) {
          addError.hidden = true
          addError.textContent = ''
        }
        if (addDialog && typeof addDialog.showModal === 'function') addDialog.showModal()
      })

      document.getElementById('fechas-add-cancel')?.addEventListener('click', function () {
        if (addForm) addForm.reset()
        if (addError) {
          addError.hidden = true
          addError.textContent = ''
        }
        if (addDialog && typeof addDialog.close === 'function') addDialog.close()
      })

      addForm?.addEventListener('submit', async function (e) {
        e.preventDefault()
        if (!addForm || !addDialog) return
        if (addError) {
          addError.hidden = true
          addError.textContent = ''
        }
        var fd = new FormData(addForm)
        var dateVal = fd.get('date')
        var cityVal = String(fd.get('city') || '').trim()
        var venueVal = String(fd.get('venue') || '').trim()
        if (!dateVal || !cityVal || !venueVal) {
          if (addError) {
            addError.textContent = 'Completa fecha, ciudad y venue.'
            addError.hidden = false
          }
          return
        }
        var payload = {
          date: String(dateVal),
          city: cityVal,
          venue: venueVal,
          status: String(fd.get('status') || 'confirmed'),
          soldOut: fd.get('soldOut') === 'on',
        }
        var timeTrim = String(fd.get('time') || '').trim()
        if (timeTrim) payload.time = timeTrim
        var ticketTrim = String(fd.get('ticketUrl') || '').trim()
        if (ticketTrim) payload.ticketUrl = ticketTrim
        var notesTrim = String(fd.get('notes') || '').trim()
        if (notesTrim) payload.notes = notesTrim
        if (addSubmit) {
          addSubmit.disabled = true
          addSubmit.textContent = 'Guardando…'
        }
        try {
          var res = await fetch('/admin/tours', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          })
          var j = await res.json()
          if (!res.ok) {
            var msg =
              (j && j.error && j.error.message) ||
              (j && j.message) ||
              'No se pudo guardar'
            if (addError) {
              addError.textContent = msg
              addError.hidden = false
            }
            return
          }
          addForm.reset()
          if (typeof addDialog.close === 'function') addDialog.close()
          await refreshToursFromServer()
        } catch {
          if (addError) {
            addError.textContent = 'Error de red'
            addError.hidden = false
          }
        } finally {
          if (addSubmit) {
            addSubmit.disabled = false
            addSubmit.textContent = 'Guardar'
          }
        }
      })

      fullRender()
    })()
  </script>

  <script>
    import { ADMIN_DELETE_ALL_BOOKINGS_CONFIRM_PHRASE } from '../../../src/lib/adminDeleteAllBookings'
    import { BOOKING_BUDGET_SORT_RANK } from '../../../src/lib/bookingBudget'
    import { buildAdminBookingDrawerRows } from '../lib/adminBookingDrawer'
    import {
      ADMIN_BOOKING_SEARCH_DEBOUNCE_MS,
      bookingMatchesAdminSearchQuery,
      normalizeAdminBookingSearchQuery,
    } from '../lib/adminBookingSearch'
    import { buildAdminBookingsCsv } from '../lib/adminExportCsv'
    import { eventDateSortKeyMs } from '../../../src/lib/eventDateSortKey'

    const budgetRanks = BOOKING_BUDGET_SORT_RANK

    function readBookingsFromDom(): Record<string, unknown>[] {
      const el = document.getElementById('admin-bookings-json')
      if (!el?.textContent) return []
      try {
        return JSON.parse(el.textContent) as Record<string, unknown>[]
      } catch {
        return []
      }
    }

    const bookingsList = readBookingsFromDom()
    const bookingsById = new Map(bookingsList.map((b) => [Number(b.id), b]))
    let activePipeline: 'all' | 'new' | 'contacted' | 'closed' = 'all'
    let activePriority: 'all' | 'high' | 'medium' | 'low' = 'all'
    let searchTimer: ReturnType<typeof setTimeout> | null = null
    let normalizedSearch = ''
    let currentDrawerId: number | null = null

    ;(function () {
      const tbody = document.querySelector('.bookings-table tbody')
      if (!tbody) return

      const budgetTh = document.querySelector('.bookings-table th[data-sort="budget"]')
      const leadScoreTh = document.querySelector('.bookings-table th[data-sort="leadScore"]')
      const createdTh = document.querySelector('.bookings-table th[data-sort="created"]')
      const eventDateTh = document.querySelector('.bookings-table th[data-sort="eventDate"]')
      let activeKey: string | null = null
      let activeDir = 'asc'

      function setIndicator(th: Element | null | undefined, dir: string) {
        document.querySelectorAll('.bookings-table th[data-sort] .sort-indicator').forEach((el) => {
          el.textContent = ''
        })
        if (!th) return
        const span = th.querySelector('.sort-indicator')
        if (span) span.textContent = dir === 'asc' ? ' ▲' : ' ▼'
      }

      function sortBy(key: string) {
        const dir = activeKey === key && activeDir === 'asc' ? 'desc' : 'asc'
        activeKey = key
        activeDir = dir
        const rows = Array.from(tbody.querySelectorAll('tr'))
        const getVal = (row: HTMLTableRowElement) => {
          if (key === 'budget') {
            const td = row.querySelector('td[data-cell="budget"]')
            const b = td?.getAttribute('data-budget') ?? ''
            return budgetRanks[b] ?? 0
          }
          if (key === 'leadScore') {
            const td = row.querySelector('td[data-cell="leadScore"]')
            const s = td?.getAttribute('data-lead-score') ?? ''
            const n = s === '' ? 0 : Number(s)
            return Number.isFinite(n) ? n : 0
          }
          if (key === 'eventDate') {
            const td = row.querySelector('td[data-cell="eventDate"]')
            const s = td?.getAttribute('data-event-date') ?? ''
            return eventDateSortKeyMs(s || null)
          }
          const td = row.querySelector('td[data-cell="created"]')
          const t = td?.getAttribute('data-timestamp')
          const n = t ? Number(t) : 0
          return Number.isFinite(n) ? n : 0
        }
        rows.sort((a, b) => {
          const va = getVal(a as HTMLTableRowElement)
          const vb = getVal(b as HTMLTableRowElement)
          if (va === vb) return 0
          const cmp = va < vb ? -1 : 1
          return dir === 'asc' ? cmp : -cmp
        })
        rows.forEach((r) => tbody.appendChild(r))
        const activeTh =
          key === 'budget'
            ? budgetTh
            : key === 'leadScore'
              ? leadScoreTh
              : key === 'eventDate'
                ? eventDateTh
                : createdTh
        setIndicator(activeTh, dir)
      }

      budgetTh?.addEventListener('click', () => sortBy('budget'))
      leadScoreTh?.addEventListener('click', () => sortBy('leadScore'))
      createdTh?.addEventListener('click', () => sortBy('created'))
      eventDateTh?.addEventListener('click', () => sortBy('eventDate'))

      function applyRowFilters() {
        for (const tr of tbody.querySelectorAll('tr')) {
          const row = tr as HTMLTableRowElement
          const id = Number(row.dataset.rowId)
          const b = bookingsById.get(id)
          if (!b) continue
          const pipe = row.dataset.pipelineStatus || 'new'
          const pipeOk = activePipeline === 'all' || pipe === activePipeline
          const pr = row.dataset.leadPriority ?? ''
          const priorityOk = activePriority === 'all' || pr === activePriority
          const searchOk = bookingMatchesAdminSearchQuery(
            { name: b.name, email: b.email, phone: b.phone as string | null },
            normalizedSearch,
          )
          row.classList.toggle('admin-row-filtered-out', !(pipeOk && priorityOk && searchOk))
        }
      }

      const bookingsToolbar = document.getElementById('admin-bookings-toolbar')
      if (bookingsToolbar) {
        bookingsToolbar.querySelectorAll('[data-pipeline-filter]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const v = (btn as HTMLElement).dataset.pipelineFilter as typeof activePipeline
            if (!v) return
            activePipeline = v
            bookingsToolbar.querySelectorAll('[data-pipeline-filter]').forEach((p) => {
              p.classList.remove('is-active')
            })
            btn.classList.add('is-active')
            applyRowFilters()
          })
        })

        bookingsToolbar.querySelectorAll('[data-priority-filter]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const v = (btn as HTMLElement).dataset.priorityFilter as typeof activePriority
            if (!v) return
            activePriority = v
            bookingsToolbar.querySelectorAll('[data-priority-filter]').forEach((p) => {
              p.classList.remove('is-active')
            })
            btn.classList.add('is-active')
            applyRowFilters()
          })
        })
      }

      const searchInput = document.getElementById('admin-booking-search') as HTMLInputElement | null
      searchInput?.addEventListener('input', () => {
        if (searchTimer) clearTimeout(searchTimer)
        searchTimer = setTimeout(() => {
          normalizedSearch = normalizeAdminBookingSearchQuery(searchInput.value)
          applyRowFilters()
        }, ADMIN_BOOKING_SEARCH_DEBOUNCE_MS)
      })

      document.getElementById('admin-export-csv')?.addEventListener('click', () => {
        const visible = [...tbody.querySelectorAll('tr')].filter(
          (tr) => !(tr as HTMLElement).classList.contains('admin-row-filtered-out'),
        )
        const list = visible
          .map((tr) => bookingsById.get(Number((tr as HTMLTableRowElement).dataset.rowId)))
          .filter((x): x is Record<string, unknown> => Boolean(x))
        const csv = buildAdminBookingsCsv(list)
        const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' })
        const a = document.createElement('a')
        const url = URL.createObjectURL(blob)
        a.href = url
        a.download = `solicitudes-${new Date().toISOString().slice(0, 10)}.csv`
        a.click()
        URL.revokeObjectURL(url)
      })

      const drawer = document.getElementById('admin-drawer')
      const drawerFields = document.getElementById('admin-drawer-fields')
      const drawerNotes = document.getElementById('admin-drawer-notes') as HTMLTextAreaElement | null
      const drawerStatus = document.getElementById('admin-drawer-status')

      function setDrawerOpen(open: boolean) {
        if (!drawer) return
        drawer.hidden = !open
        if (!open) currentDrawerId = null
      }

      document.querySelectorAll('[data-close-drawer]').forEach((el) => {
        el.addEventListener('click', () => setDrawerOpen(false))
      })

      function renderDrawerFields(booking: Record<string, unknown>) {
        if (!drawerFields) return
        drawerFields.replaceChildren()
        const dl = document.createElement('dl')
        dl.className = 'admin-drawer-dl'
        for (const { label, value } of buildAdminBookingDrawerRows(booking)) {
          const dt = document.createElement('dt')
          dt.textContent = label
          const dd = document.createElement('dd')
          dd.textContent = value
          dl.appendChild(dt)
          dl.appendChild(dd)
        }
        drawerFields.appendChild(dl)
      }

      tbody.addEventListener('click', (e) => {
        const t = e.target as HTMLElement | null
        const openId = t?.closest('[data-open-drawer]')?.getAttribute('data-open-drawer')
        if (openId) {
          const id = Number(openId)
          const b = bookingsById.get(id)
          if (!b || !drawerNotes) return
          currentDrawerId = id
          renderDrawerFields(b)
          drawerNotes.value =
            typeof b.internalNotes === 'string' ? b.internalNotes : b.internalNotes == null ? '' : String(b.internalNotes)
          if (drawerStatus) drawerStatus.textContent = ''
          setDrawerOpen(true)
          drawerNotes.focus()
          return
        }
        const delId = t?.closest('[data-soft-delete]')?.getAttribute('data-soft-delete')
        if (delId) {
          const id = Number(delId)
          if (!Number.isInteger(id) || id <= 0) return
          if (!confirm(`¿Ocultar solicitud #${id}? Podrás restaurarla por SQL si hace falta.`)) return
          fetch('/admin/delete-booking', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ bookingId: id }),
          })
            .then(async (res) => {
              const j = (await res.json()) as { ok?: boolean; message?: string }
              if (!res.ok || !j.ok) {
                alert(j.message ?? 'No se pudo eliminar')
                return
              }
              window.location.reload()
            })
            .catch(() => alert('Error de red al eliminar'))
        }
      })

      document.getElementById('admin-drawer-save-notes')?.addEventListener('click', () => {
        if (currentDrawerId == null || !drawerNotes) return
        if (drawerStatus) drawerStatus.textContent = 'Guardando…'
        fetch('/admin/save-internal-notes', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            bookingId: currentDrawerId,
            internalNotes: drawerNotes.value.trim() === '' ? null : drawerNotes.value,
          }),
        })
          .then(async (res) => {
            const j = (await res.json()) as { ok?: boolean; message?: string }
            if (!res.ok || !j.ok) {
              if (drawerStatus) drawerStatus.textContent = j.message ?? 'Error al guardar'
              return
            }
            const b = bookingsById.get(currentDrawerId!)
            if (b) {
              b.internalNotes =
                drawerNotes.value.trim() === '' ? null : drawerNotes.value
            }
            if (drawerStatus) drawerStatus.textContent = 'Notas guardadas.'
            const row = tbody.querySelector(`tr[data-row-id="${currentDrawerId}"]`)
            const cell = row?.querySelector('.admin-notes-preview')
            if (cell && b) {
              const raw = typeof b.internalNotes === 'string' ? b.internalNotes : ''
              cell.textContent =
                raw.trim() === ''
                  ? '—'
                  : raw.length > 40
                    ? `${raw.slice(0, 40)}…`
                    : raw
              ;(cell as HTMLElement).title = raw
            }
            renderDrawerFields(b ?? {})
          })
          .catch(() => {
            if (drawerStatus) drawerStatus.textContent = 'Error de red'
          })
      })

      const deleteAllModal = document.getElementById('admin-delete-all-modal')
      const phraseInput = document.getElementById('admin-delete-all-phrase') as HTMLInputElement | null
      const deleteAllSubmit = document.getElementById('admin-delete-all-submit') as HTMLButtonElement | null
      const deleteAllDry = document.getElementById('admin-delete-all-dry') as HTMLButtonElement | null
      const deleteAllDryResult = document.getElementById('admin-delete-all-dry-result')
      const deleteAllModalErr = document.getElementById('admin-delete-all-modal-error')
      const deleteAllPhrase = ADMIN_DELETE_ALL_BOOKINGS_CONFIRM_PHRASE

      function setDeleteAllModalOpen(open: boolean) {
        if (!deleteAllModal) return
        deleteAllModal.hidden = !open
        if (!open && phraseInput) phraseInput.value = ''
        if (deleteAllModalErr) {
          deleteAllModalErr.hidden = true
          deleteAllModalErr.textContent = ''
        }
        if (deleteAllDryResult) {
          deleteAllDryResult.hidden = true
          deleteAllDryResult.textContent = ''
        }
        syncDeleteAllSubmit()
      }

      function syncDeleteAllSubmit() {
        if (!deleteAllSubmit || !phraseInput) return
        const busy = deleteAllSubmit.dataset.loading === '1'
        deleteAllSubmit.disabled = busy || phraseInput.value.trim() !== deleteAllPhrase
      }

      phraseInput?.addEventListener('input', syncDeleteAllSubmit)

      document.getElementById('admin-open-delete-all')?.addEventListener('click', () => {
        setDeleteAllModalOpen(true)
      })

      document.querySelectorAll('[data-close-delete-all-modal]').forEach((el) => {
        el.addEventListener('click', () => setDeleteAllModalOpen(false))
      })

      deleteAllDry?.addEventListener('click', () => {
        if (!deleteAllDryResult || !deleteAllDry) return
        deleteAllDry.disabled = true
        if (deleteAllModalErr) {
          deleteAllModalErr.hidden = true
          deleteAllModalErr.textContent = ''
        }
        fetch('/admin/delete-all-bookings', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ dryRun: true }),
        })
          .then(async (res) => {
            const j = (await res.json()) as {
              ok?: boolean
              data?: { count?: number }
              message?: string
            }
            if (!res.ok || !j.ok) {
              if (deleteAllModalErr) {
                deleteAllModalErr.hidden = false
                deleteAllModalErr.textContent = j.message ?? 'Error'
              }
              return
            }
            const c = typeof j.data?.count === 'number' ? j.data.count : '—'
            deleteAllDryResult.hidden = false
            deleteAllDryResult.textContent = `Filas en base (todas, incl. ocultas): ${c}`
          })
          .catch(() => {
            if (deleteAllModalErr) {
              deleteAllModalErr.hidden = false
              deleteAllModalErr.textContent = 'Error de red'
            }
          })
          .finally(() => {
            deleteAllDry.disabled = false
          })
      })

      deleteAllSubmit?.addEventListener('click', () => {
        if (!phraseInput || phraseInput.value.trim() !== deleteAllPhrase || !deleteAllSubmit) return
        deleteAllSubmit.dataset.loading = '1'
        deleteAllSubmit.disabled = true
        if (deleteAllModalErr) {
          deleteAllModalErr.hidden = true
          deleteAllModalErr.textContent = ''
        }
        fetch('/admin/delete-all-bookings', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ confirm: deleteAllPhrase }),
        })
          .then(async (res) => {
            const j = (await res.json()) as {
              ok?: boolean
              data?: { deletedCount?: number }
              message?: string
              code?: string
            }
            if (!res.ok || !j.ok) {
              if (deleteAllModalErr) {
                deleteAllModalErr.hidden = false
                deleteAllModalErr.textContent = j.message ?? j.code ?? 'Error'
              }
              return
            }
            const n = typeof j.data?.deletedCount === 'number' ? j.data.deletedCount : 0
            window.location.replace(
              `/admin?bulkDeleted=ok&count=${encodeURIComponent(String(n))}`,
            )
          })
          .catch(() => {
            if (deleteAllModalErr) {
              deleteAllModalErr.hidden = false
              deleteAllModalErr.textContent = 'Error de red'
            }
          })
          .finally(() => {
            delete deleteAllSubmit.dataset.loading
            syncDeleteAllSubmit()
          })
      })

      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && deleteAllModal && !deleteAllModal.hidden) {
          setDeleteAllModalOpen(false)
          return
        }
        if (e.key === 'Escape' && drawer && !drawer.hidden) setDrawerOpen(false)
      })
    })()
  </script>
</MarketingLayout>

