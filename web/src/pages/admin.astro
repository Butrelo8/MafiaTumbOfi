      <div id="admin-drawer-fields" class="admin-drawer-fields"></div>
      <div class="admin-drawer-notes-block">
        <label class="admin-drawer-notes-label" for="admin-drawer-notes">Notas internas</label>
        <textarea id="admin-drawer-notes" class="admin-drawer-notes" rows="5" maxlength="10000"></textarea>
        <div class="admin-drawer-notes-actions">
          <button type="button" class="btn-secondary" id="admin-drawer-save-notes">Guardar notas</button>
