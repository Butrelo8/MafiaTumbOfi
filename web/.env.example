# API origin only — no path. Do not set to .../api (code appends /api/...). Trailing slash is stripped.
# Dev: backend on port 3001 (see root .env PORT).
PUBLIC_API_URL=http://localhost:3001

# Optional: override JSON "version" in GET /health and GET /api/health (same vars as API; e.g. git SHA on Vercel).
# APP_VERSION=
# RELEASE_VERSION=

# Site URL for canonical / Open Graph on marketing pages (no trailing slash). Falls back to request origin if unset.
# PUBLIC_SITE_URL=https://tudominio.com

# Optional: set to false or 0 on preview deployments to emit robots noindex (see `web/src/components/Seo.astro`).
# PUBLIC_ALLOW_INDEXING=true

# Optional: Plausible Analytics — hostname as registered in Plausible (no https://), e.g. mafiatumbada.com.
# Loads script in MarketingLayout + custom events (hero CTA, ticket CTAs, booking submit). Omit to disable.
# PUBLIC_PLAUSIBLE_DOMAIN=mafiatumbada.com

# Optional: press kit — WhatsApp wa.me link; asset download URLs (Drive, Dropbox, CDN).
# PUBLIC_WHATSAPP_URL=https://wa.me/521XXXXXXXXXX
# PUBLIC_PRESS_PHOTOS_URL=
# PUBLIC_PRESS_LOGO_URL=
# PUBLIC_PRESS_BIO_URL=

# ─── Clerk (same Dashboard app as the API) ─────────────────
# Astro does not load the repo root `.env`; copy keys here for `cd web && bun dev`.
# Root `.env` (Hono API) holds `ADMIN_CLERK_ID` — that is the only place to set which Clerk user id is admin on
# `/api/admin/*`. See root `.env.example` (Admin / Clerk sections). Do not duplicate `ADMIN_CLERK_ID` in web/.
#
# Publishable key → browser; secret → SSR (`clerkMiddleware`, `auth()`).
#PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
