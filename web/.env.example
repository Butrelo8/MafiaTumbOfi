# API base URL (no trailing slash). Dev: backend on port 3001 (see root .env PORT).
PUBLIC_API_URL=http://localhost:3001

# Clerk — get from https://dashboard.clerk.com (same app as backend)
# Publishable key is used in the browser; secret key is required for server-side auth (middleware, auth()).
PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
