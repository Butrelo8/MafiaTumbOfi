# ─── App ─────────────────────────────────────────────
# Use 3001 to avoid clash with other apps on 3000/5000
PORT=3001
NODE_ENV=development
# Optional: override GET /health "version" (e.g. git SHA). If unset, uses package.json "version".
# APP_VERSION=
# RELEASE_VERSION=
FRONTEND_URL=http://localhost:4321
# Optional: for CORS when using multiple frontends
# STAGING_URL=
# Production frontend origin for CORS (no path; scheme+host[+port]). Trailing slash is OK; www and apex are both allowed if either is set.
# PRODUCTION_URL=
# Optional on API: public site URL (drip links, Clerk authorizedParties when set). Expansion adds the paired www or apex host automatically.
# PUBLIC_SITE_URL=

# ─── Database (SQLite / Turso) ───────────────────────
# Default file DB when Turso env is unset (local dev, tests, CI).
DB_PATH=./data/sqlite.db

# Turso (libsql) — optional. From `turso db show <name> --url` and `turso db tokens create <name>`.
# Windows CLI: WSL: `curl -sSfL https://get.tur.so/install.sh | bash` or https://docs.turso.tech/cli/overview# TURSO_DATABASE_URL=libsql://your-db-org.turso.io
# TURSO_AUTH_TOKEN=
# When both are set:
#   - Omit DB_PATH (or leave unset) → API uses remote Turso only (Render production).
#   - Set DB_PATH (e.g. ./data/local.db) → embedded replica: local file + syncUrl to Turso (fast local reads).
# When Turso vars are unset, DB_PATH (or repo default data/sqlite.db) uses bun:sqlite.

# ─── Admin (Clerk) ───────────────────────────────────
# Clerk user id (`sub` in JWT) that may access /api/admin/* — required for admin in production.
# Local: paste your Clerk user id from Dashboard → Users. New signups never auto-become admin.
# ADMIN_CLERK_ID=user_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Email — Resend (booking form) ───────────────────
RESEND_API_KEY=
BOOKING_NOTIFICATION_EMAIL=
# Optional: verified sender (default: onboarding@resend.dev)
# RESEND_FROM_EMAIL=noreply@tudominio.com

# ─── Email — booking nurture drip (cron → internal route) ─
# Shared secret: API checks Bearer; Render cron sends same value.
# DRIP_CRON_SECRET=
# Hours after booking `created_at` (defaults: 24 / 72)
# DRIP_EMAIL_2_DELAY_HOURS=24
# DRIP_EMAIL_3_DELAY_HOURS=72
# Max rows processed per stage per cron tick (default 20, max 500)
# DRIP_BATCH_SIZE=20
# Links in drip HTML/text (first non-empty wins): PUBLIC_SITE_URL, PRODUCTION_URL, FRONTEND_URL
# PUBLIC_SITE_URL=https://tu-sitio.com
# Email 2 "how we sound" video link (override without code deploy)
# DRIP_VIDEO_URL=https://www.youtube.com/watch?v=7Sx0yDjGoq0
# Email 3 primary CTA — WhatsApp (same as web; optional — falls back to booking form)
# PUBLIC_WHATSAPP_URL=https://wa.me/5215512345678?text=Hola

# ─── Admin — delete all bookings (danger) ────────────
# Default-deny: POST /api/admin/bookings/delete-all returns 403 unless ALLOW_ADMIN_DELETE_ALL_BOOKINGS=true
# OR NODE_ENV=development. Hard-deletes every row in `bookings` (including soft-deleted). Use for demos only.
# ALLOW_ADMIN_DELETE_ALL_BOOKINGS=true

# ─── Admin — booking export ───────────────────────────
# Default-deny: GET /api/admin/export/bookings returns 403 unless ALLOW_ADMIN_BOOKING_EXPORT=true
# OR NODE_ENV=development (local). On production hosts use NODE_ENV=production and enable only briefly.
# ALLOW_ADMIN_BOOKING_EXPORT=true
# Max rows per export response (default 10000, hard ceiling 50000). Larger DBs get truncated + warning in JSON.
# ADMIN_EXPORT_MAX_ROWS=10000

# ─── Auth — Clerk (Admin panel) ───────────────────────
# Get from https://dashboard.clerk.com — the API must have BOTH keys (not only web/.env).
# @clerk/backend authenticateRequest() requires publishable + secret; missing publishable → 500 on /api/admin/*.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional: same value as CLERK_PUBLISHABLE_KEY; API reads this if CLERK_PUBLISHABLE_KEY is unset
# PUBLIC_CLERK_PUBLISHABLE_KEY=
# Optional: for user/session webhooks
# CLERK_WEBHOOK_SECRET=

# ─── Payments — Stripe (Ticket sales / merch, future) ─
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Monitoring (optional) ────────────────────────────
# SENTRY_DSN=
