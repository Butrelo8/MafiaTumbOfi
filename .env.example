# ─── App ─────────────────────────────────────────────
# Use 3001 to avoid clash with other apps on 3000/5000
PORT=3001
NODE_ENV=development
# Optional: override GET /health "version" (e.g. git SHA). If unset, uses package.json "version".
# APP_VERSION=
# RELEASE_VERSION=
FRONTEND_URL=http://localhost:4321
# Optional: for CORS when using multiple frontends
# STAGING_URL=
# Production frontend origin for CORS (no path; scheme+host[+port]). Trailing slash is OK; www and apex are both allowed if either is set.
# PRODUCTION_URL=

# ─── Database (SQLite) ───────────────────────────────
DB_PATH=./data/sqlite.db

# ─── Email — Resend (booking form) ───────────────────
RESEND_API_KEY=
BOOKING_NOTIFICATION_EMAIL=
# Optional: verified sender (default: onboarding@resend.dev)
# RESEND_FROM_EMAIL=noreply@tudominio.com

# ─── Admin — booking export ───────────────────────────
# Default-deny: GET /api/admin/export/bookings returns 403 unless ALLOW_ADMIN_BOOKING_EXPORT=true
# OR NODE_ENV=development (local). On production hosts use NODE_ENV=production and enable only briefly.
# ALLOW_ADMIN_BOOKING_EXPORT=true
# Max rows per export response (default 10000, hard ceiling 50000). Larger DBs get truncated + warning in JSON.
# ADMIN_EXPORT_MAX_ROWS=10000

# ─── Auth — Clerk (Admin panel) ───────────────────────
# Get from https://dashboard.clerk.com (API needs both; frontend uses publishable)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional: same as CLERK_PUBLISHABLE_KEY; backend falls back to this if set
# PUBLIC_CLERK_PUBLISHABLE_KEY=
# Optional: for user/session webhooks
# CLERK_WEBHOOK_SECRET=

# ─── Payments — Stripe (Ticket sales / merch, future) ─
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Monitoring (optional) ────────────────────────────
# SENTRY_DSN=
